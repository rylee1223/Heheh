-- ═══════════════════════════════════════════════════════════
--  STATS & INV UPDATER
-- ═══════════════════════════════════════════════════════════
task.spawn(function()
    while task.wait(1) do
        local pstats = player:FindFirstChild("playerstats")
        if pstats then
            local stored = pstats:FindFirstChild("Stored")
            if stored then statStorage.Text = "💾 Stored: " .. fmt(tonumber(stored.Value) or 0) end
        end
        statCases.Text = "💼 Opened: " .. tostring(opened)
        if loop then
            local e = tick() - startT
            statUptime.Text = ("⏱ Uptime: %02d:%02d"):format(e/60, e%60)
        end
        
        -- Update Inventory GUI safely
        for _, c in ipairs(invScroll:GetChildren()) do
            if c:IsA("TextLabel") then c:Destroy() end
        end
        local pinv = player:FindFirstChild("inventory") or player:FindFirstChild("Inventory")
        if pinv then
            local hasItem = false
            local function scanGUI(parent)
                for _, it in ipairs(parent:GetChildren()) do
                    if (it:IsA("IntValue") or it:IsA("NumberValue")) and it.Value > 0 then
                        hasItem = true
                        local lbl = Instance.new("TextLabel")
                        lbl.Size = UDim2.new(1,0,0,16)
                        lbl.BackgroundTransparency = 1
                        lbl.Text = it.Name .. ": " .. fmt(it.Value)
                        lbl.TextColor3 = C.grey
                        lbl.TextSize = 10
                        lbl.Font = Enum.Font.Code
                        lbl.TextXAlignment = Enum.TextXAlignment.Left
                        lbl.Parent = invScroll
                    elseif it:IsA("Folder") then
                        scanGUI(it)
                    end
                end
            end
            scanGUI(pinv)
            if not hasItem then
                local lbl = Instance.new("TextLabel")
                lbl.Size = UDim2.new(1,0,0,16)
                lbl.BackgroundTransparency = 1
                lbl.Text = "Empty..."
                lbl.TextColor3 = C.dim
                lbl.TextSize = 10
                lbl.Font = Enum.Font.Code
                lbl.Parent = invScroll
            end
        end
    end
end)

-- ═══════════════════════════════════════════════════════════
--  FARMING LOGIC (HYPER-SPEED HEARTBEAT)
-- ═══════════════════════════════════════════════════════════
local function startFarming()
    if loop then return end
    loop = true
    opened = 0
    startT = tick()
    farmBtn.Text = "■ STOP"
    farmBtn.TextColor3 = C3(255,200,180)
    farmBtn.BackgroundColor3 = C.dangerDark
    cachePrompt()
    
    -- ABSOLUTE MAXIMUM SPEED: Fires every single frame (~60 times a second)
    conn = RunService.Heartbeat:Connect(fire)
end

local function stopFarming()
    if not loop then return end
    loop = false
    farmBtn.Text = "▶ START"
    farmBtn.TextColor3 = C.amber
    farmBtn.BackgroundColor3 = C.amberDark
    if conn then conn:Disconnect(); conn = nil end
    updateDiscord()
end

farmBtn.MouseButton1Click:Connect(function()
    if loop then stopFarming() else startFarming() end
end)

-- Watch for late-loading cases
task.spawn(function()
    local wb = workspace:WaitForChild("World Building", 30)
    if not wb then return end
    local cs = wb:WaitForChild("Cases", 10)
    if not cs then return end
    cachePrompt()
    cs.ChildAdded:Connect(function() task.defer(cachePrompt) end)
end)

-- ═══════════════════════════════════════════════════════════
--  DRAG
-- ═══════════════════════════════════════════════════════════
local drag, dragStart, startPos, input
header.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        drag, dragStart, startPos = true, i.Position, main.Position
        i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then drag = false end end)
    end
end)
header.InputChanged:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseMovement then input = i end
end)
UIS.InputChanged:Connect(function(i)
    if drag and i == input then
        local d = i.Position - dragStart
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X, startPos.Y.Scale, startPos.Y.Offset+d.Y)
    end
end)

-- ═══════════════════════════════════════════════════════════
--  INSTANT START
-- ═══════════════════════════════════════════════════════════
cachePrompt()
startFarming()
