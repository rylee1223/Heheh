    end)
end

--// ================================================
--// MULTI-PLAYER DISCORD BOT SYSTEM
--// Finds which slot matches this player, then
--// edits that slot's message by ID (no new messages created).
--// ================================================

-- Find which CONFIG.PLAYERS slot belongs to this player (Strictly using Username via player.Name)
local mySlot = nil
for _, slot in pairs(CONFIG.PLAYERS) do
    if string.lower(slot.USERNAME) == string.lower(player.Name) then
        mySlot = slot
        break
    end
end

-- Runtime message ID (must be provided in config to edit)
local linkedMessageId = (mySlot and mySlot.MESSAGE_ID ~= "") and mySlot.MESSAGE_ID or nil

local function discordRequest(method, endpoint, body)
    if CONFIG.BOT_TOKEN == "" or CONFIG.CHANNEL_ID == "" then return nil, "Missing Token/Channel" end
    local req = (syn and syn.request)
             or (http and http.request)
             or http_request
             or request
    if not req then return nil, "Executor missing HTTP function" end

    local success, response = pcall(function()
        return req({
            Url    = "https://discord.com/api/v10" .. endpoint,
            Method = method,
            Headers = {
                ["Authorization"] = "Bot " .. CONFIG.BOT_TOKEN,
                ["Content-Type"]  = "application/json",
            },
            Body = body and HttpService:JSONEncode(body) or nil,
        })
    end)

    if not success then
        warn("[GiftFarmer] HTTP Request crashed: " .. tostring(response))
        return nil, "Request crashed"
    end

    if response and response.StatusCode then
        if response.StatusCode >= 200 and response.StatusCode < 300 then
            if response.Body and response.Body ~= "" then
                return HttpService:JSONDecode(response.Body), nil
            end
            return true, nil
        else
            local errBody = response.Body or "No body"
            warn("[GiftFarmer] Discord API Error " .. tostring(response.StatusCode) .. ": " .. errBody)
            return nil, "API Error " .. tostring(response.StatusCode)
        end
    end

    return nil, "No response"
end

-- Build embed for this player (Uses player.Name for Username)
local function buildEmbed(collected, rate, elapsed, currentTotal)
    local uptimeStr = string.format(
        "%02d:%02d", math.floor(elapsed/60), math.floor(elapsed%60)
    )
    local slotIndex = "?"
    if mySlot then
        for i, s in pairs(CONFIG.PLAYERS) do
            if s == mySlot then slotIndex = tostring(i) break end
        end
    end

    return {
        content = " ", -- Discord requires content to not be empty if embeds are missing, added space for safety
        embeds = {{
            title  = "🎁  Gift Farmer — Player " .. slotIndex .. " Live",
            color  = 14680064,
            fields = {
                {name = "👤 Player",    value = "```" .. player.Name  .. "```", inline = true},
                {name = "📦 Collected", value = "```" .. tostring(collected)   .. "```", inline = true},
                {name = "💰 Total",     value = "```" .. tostring(currentTotal) .. "```", inline = true},
                {name = "⚡ Rate",      value = "```" .. tostring(rate) .. " / min```",  inline = true},
                {name = "⏱ Uptime",    value = "```" .. uptimeStr .. "```",              inline = true},
                {name = "📡 Status",    value = "```" .. (enabled and "Farming" or "Idle") .. "```", inline = true},
            },
            footer    = {text = "Slot " .. slotIndex .. " of 4  •  Last updated"},
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
            thumbnail = {
                url = "https://www.roblox.com/headshot-thumbnail/image?userId="
                    .. player.UserId .. "&width=420&height=420&format=png"
            },
        }}
    }
end

-- Edit the message for this player (Does NOT create new messages)
local function updateDiscord(collected, rate, elapsed)
    if CONFIG.BOT_TOKEN == "" or CONFIG.CHANNEL_ID == "" then return end
    if not mySlot then return end -- this player is not in the PLAYERS list
    if not linkedMessageId then return end -- no message ID provided

    local now = tick()
    if now - lastUpdateTime < (CONFIG.UPDATE_INTERVAL * 60) then return end
    lastUpdateTime = now

    local currentTotal = getStatValue()
    local embedData    = buildEmbed(collected, rate, elapsed, currentTotal)

    task.spawn(function()
        -- PATCH = strictly edit existing message by ID
        local result, err = discordRequest(
            "PATCH",
            "/channels/" .. CONFIG.CHANNEL_ID .. "/messages/" .. linkedMessageId,
            embedData
        )
        if err then
            warn("[GiftFarmer] Failed to edit message " .. linkedMessageId .. ". Error: " .. tostring(err))
        else
            print("[GiftFarmer] Successfully edited message " .. linkedMessageId)
        end
    end)
end

