-- ============================================================
--  CASE FARMER GUI  —  Config
local DEFAULT_CASE = 10   -- Which case to start on (1–10)
-- ============================================================

local CONFIG = {
    BOT_TOKEN = "GITHUB_PLACEHOLDER", -- Loader replaces this securely
    CHANNEL_ID = "1517885492258013184",
    UPDATE_INTERVAL = 5, -- Discord updates every 5 minutes
    PLAYERS = {
        {USERNAME = "Build3r_MAGIC2012", MESSAGE_ID = "1518758643166875681"},
        {USERNAME = "odtgPixelTiger", MESSAGE_ID = "1518758669922336828"},
        {USERNAME = "qak_HazeMoonHD5705", MESSAGE_ID = "1518758690235224208"},
        {USERNAME = "dimdam457secholder", MESSAGE_ID = "1518758703824633916"},
    },
}

local Players         = game:GetService("Players")
local RunService      = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualUser     = game:GetService("VirtualUser")
local HttpService     = game:GetService("HttpService")

local player    = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Anti-AFK
player.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())
end)

if playerGui:FindFirstChild("CaseFarmingGUI") then playerGui.CaseFarmingGUI:Destroy() end

-- ── State ────────────────────────────────────────────────────
local selectedCase   = DEFAULT_CASE
local isLooping      = false
local farmConnection = nil
local dropdownOpen   = false
local startTime      = 0
local lastUpdateTime = 0
local casesOpened    = 0

-- ── Discord Slot Finder ──────────────────────────────────────
local mySlot = nil
for _, slot in pairs(CONFIG.PLAYERS) do
    if string.lower(slot.USERNAME) == string.lower(player.Name) then mySlot = slot; break end
end
local linkedMessageId = (mySlot and mySlot.MESSAGE_ID ~= "") and mySlot.MESSAGE_ID or nil

-- ── Number Formatters ────────────────────────────────────────
local function formatSuffix(num)
    num = tonumber(num) or 0
    if num >= 1e12 then return string.format("%.2fT", num / 1e12)
    elseif num >= 1e9 then return string.format("%.2fB", num / 1e9)
    elseif num >= 1e6 then return string.format("%.2fM", num / 1e6)
    elseif num >= 1e3 then return string.format("%.2fK", num / 1e3)
    else return tostring(math.floor(num)) end
end

local function formatCommas(num)
    num = tonumber(num) or 0
    local s = tostring(math.floor(num))
    while true do s, _ = string.gsub(s, "^(-?%d+)(%d%d%d)", '%1,%2'); if _ == 0 then break end end
    return s
end

-- ── Helpers ──────────────────────────────────────────────────
local function getPrompt(num)
    local cases = workspace:FindFirstChild("World Building")
    if not cases then return nil end
    local folder = cases:FindFirstChild("Case_" .. num)
    if not folder then return nil end
    local base = folder:FindFirstChild("Base")
    return base and base:FindFirstChild("ProximityPrompt")
end

local function firePrompt(prompt)
    if not prompt then return end
    prompt.HoldDuration = 0
    prompt.Enabled = true
    casesOpened += 1
    if fireproximityprompt then fireproximityprompt(prompt)
    else prompt:InputHoldBegin(); prompt:InputHoldEnd() end
end

-- ── Discord Functions ────────────────────────────────────────
local function discordRequest(method, endpoint, body)
    if CONFIG.BOT_TOKEN == "" or CONFIG.BOT_TOKEN == "GITHUB_PLACEHOLDER" or CONFIG.CHANNEL_ID == "" then return nil, "Missing Token" end
    local req = (syn and syn.request) or (http and http.request) or http_request or request
    if not req then return nil, "No HTTP" end

    local success, response = pcall(function()
        return req({
            Url = "https://discord.com/api/v10" .. endpoint,
            Method = method,
            Headers = {["Authorization"] = "Bot " .. CONFIG.BOT_TOKEN, ["Content-Type"] = "application/json"},
            Body = body and HttpService:JSONEncode(body) or nil,
        })
    end)
    if not success then return nil, "Crash" end
    if response and response.StatusCode >= 200 and response.StatusCode < 300 then return true, nil end
    return nil, "API Error " .. tostring(response.StatusCode)
end

local function getInventoryString()
    local inv = player:FindFirstChild("inventory")
    if not inv then return "No Inventory Found" end
    local str = ""
    for _, item in pairs(inv:GetChildren()) do
        if item:IsA("ValueBase") then str = str .. item.Name .. ": " .. formatSuffix(item.Value) .. "\n" end
    end
    return (str == "") and "Empty" or (#str > 1000 and str:sub(1, 997) .. "..." or str)
end

local function getStoredStat()
    local stats = player:FindFirstChild("playerstats")
    if not stats then return 0 end
    local stored = stats:FindFirstChild("Stored")
    return stored and tonumber(stored.Value) or 0
end

local function updateDiscord()
    if CONFIG.BOT_TOKEN == "GITHUB_PLACEHOLDER" or not mySlot or not linkedMessageId then return end
    local now = tick()
    if now - lastUpdateTime < (CONFIG.UPDATE_INTERVAL * 60) then return end
    lastUpdateTime = now

    local elapsed = now - startTime
    local uptimeStr = string.format("%02d:%02d", math.floor(elapsed/60), math.floor(elapsed%60))
    local slotIndex = "?"
    for i, s in pairs(CONFIG.PLAYERS) do if s == mySlot then slotIndex = tostring(i); break end end

    local storedRaw = getStoredStat()
    local storedDisplay = formatCommas(storedRaw) .. " (" .. formatSuffix(storedRaw) .. ")"

    task.spawn(function()
        discordRequest("PATCH", "/channels/" .. CONFIG.CHANNEL_ID .. "/messages/" .. linkedMessageId, {
            content = " ",
            embeds = {{
                title = "📦 Case Farmer — Player " .. slotIndex .. " Live",
                color = 3447003,
                fields = {
                    {name = "👤 Player", value = "```" .. player.Name .. "```", inline = true},
                    {name = "💼 Cases Opened", value = "```" .. tostring(casesOpened) .. "```", inline = true},
                    {name = "🎯 Case Type", value = "```Case " .. tostring(selectedCase) .. "```", inline = true},
                    {name = "📡 Status", value = "```" .. (isLooping and "Farming" or "Idle") .. "```", inline = true},
                    {name = "⏱ Uptime", value = "```" .. uptimeStr .. "```", inline = true},
                    {name = "💾 Stored", value = "```" .. storedDisplay .. "```", inline = true},
                    {name = "🎒 Inventory", value = "```\n" .. getInventoryString() .. "```", inline = false},
                },
                footer = {text = "Slot " .. slotIndex .. " of 4 • Updates every " .. CONFIG.UPDATE_INTERVAL .. " min"},
                timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
                thumbnail = {url = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. player.UserId .. "&width=420&height=420&format=png"}
            }}
        })
    end)
end

-- ── Palette & UI Helpers ─────────────────────────────────────
local C = {
    bg = Color3.fromRGB(14, 14, 18), surface = Color3.fromRGB(22, 22, 28), elevated = Color3.fromRGB(30, 30, 38),
    border = Color3.fromRGB(45, 45, 55), accent = Color3.fromRGB(85, 120, 245), accentDim = Color3.fromRGB(50, 75, 160),
    danger = Color3.fromRGB(190, 55, 55), success = Color3.fromRGB(60, 180, 115),
    textPri = Color3.fromRGB(235, 235, 245), textSec = Color3.fromRGB(125, 125, 140), textMuted = Color3.fromRGB(70, 70, 85)
}

local function stroke(p, c, t, tr) local s = Instance.new("UIStroke"); s.Color, s.Thickness, s.Transparency, s.Parent = c or C.border, t or 1, tr or 0, p; return s end
local function corner(p, r) local c = Instance.new("UICorner"); c.CornerRadius, c.Parent = UDim.new(0, r or 6), p; return c end

-- ── Root & Main Frame ────────────────────────────────────────
