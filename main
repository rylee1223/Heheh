-- Dynamic Inventory GUI Updater
local function refreshInventory()
    for _, child in ipairs(invScroll:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    local invFolder = player:FindFirstChild("inventory")
    if not invFolder then 
        local noInv = Instance.new("TextLabel")
        noInv.Size = UDim2.new(1, 0, 0, 20)
        noInv.BackgroundTransparency = 1
        noInv.Text = "No inventory found"
        noInv.TextColor3 = C.textMuted
        noInv.TextSize = 12
        noInv.Font = Enum.Font.Gotham
        noInv.LayoutOrder = 1
        noInv.Parent = invScroll
        return 
    end

    local items = invFolder:GetChildren()
    if #items == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 20)
        empty.BackgroundTransparency = 1
        empty.Text = "Inventory is empty"
        empty.TextColor3 = C.textMuted
        empty.TextSize = 12
        empty.Font = Enum.Font.Gotham
        empty.LayoutOrder = 1
        empty.Parent = invScroll
    else
        for i, item in ipairs(items) do
            local row = Instance.new("Frame")
            row.Size = UDim2.new(1, 0, 0, 22)
            row.BackgroundColor3 = C.elevated
            row.BackgroundTransparency = 0.4
            row.LayoutOrder = i
            row.Parent = invScroll
            corner(row, 4)

            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(0.65, 0, 1, 0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = item.Name
            nameLabel.TextColor3 = C.textPri
            nameLabel.TextSize = 12
            nameLabel.Font = Enum.Font.Gotham
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.Parent = row

            local amountLabel = Instance.new("TextLabel")
            amountLabel.Size = UDim2.new(0.35, 0, 1, 0)
            amountLabel.Position = UDim2.new(0.65, 0, 0, 0)
            amountLabel.BackgroundTransparency = 1
            amountLabel.Text = formatNumber(item.Value) -- Apply formatting here too
            amountLabel.TextColor3 = C.accent
            amountLabel.TextSize = 12
            amountLabel.Font = Enum.Font.GothamBold
            amountLabel.TextXAlignment = Enum.TextXAlignment.Right
            amountLabel.Parent = row
            
            item.Changed:Connect(function()
                if amountLabel and amountLabel.Parent then
                    amountLabel.Text = formatNumber(item.Value)
                end
            end)
        end
    end
end

-- Hook up inventory events
local invFolder = player:WaitForChild("inventory", 10)
if invFolder then
    invFolder.ChildAdded:Connect(function() task.defer(refreshInventory) end)
    invFolder.ChildRemoved:Connect(function() task.defer(refreshInventory) end)
end
task.defer(refreshInventory)

-- ── Main Loop for Discord Updates ────────────────────────────
RunService.Heartbeat:Connect(function()
    if isLooping then
        updateDiscord()
    end
end)

-- ── Dragging ─────────────────────────────────────────────────
local dragging, dragInput, dragStart, startPos

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

titleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
