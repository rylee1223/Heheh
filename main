local function makeBtn(parent, text, yPos, accent)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0.9, 0, 0, 44)
    btn.Position = UDim2.new(0.05, 0, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(18, 10, 26)
    btn.Text = text
    btn.Font = Enum.Font.GothamBold
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextSize = 13
    btn.ZIndex = 3
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 12)

    local s = Instance.new("UIStroke", btn)
    s.Color = accent
    s.Thickness = 1.5

    Instance.new("UIGradient", btn).Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(28, 16, 38)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(16, 8,  22))
    })

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = Color3.fromRGB(34, 18, 46)}):Play()
        TweenService:Create(s,   TweenInfo.new(0.12), {Thickness = 2.2}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = Color3.fromRGB(18, 10, 26)}):Play()
        TweenService:Create(s,   TweenInfo.new(0.12), {Thickness = 1.5}):Play()
    end)
    btn.MouseButton1Click:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.06), {Size = UDim2.new(0.86, 0, 0, 40)}):Play()
        task.delay(0.09, function()
            TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(0.9, 0, 0, 44)}):Play()
        end)
    end)
    return btn
end

