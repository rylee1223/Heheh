--// VALUE SOURCE
local eventCurrencyStat = player
    :WaitForChild("playerstats")
    :WaitForChild("EventCurrency")

local function getStatValue()
    return tonumber(eventCurrencyStat.Value) or 0
end

--// RATE CALCULATOR
local function logCollection(currentVal)
    local now = tick()
    if currentVal > lastKnownValue then
        table.insert(collectLog, {t = now, v = currentVal - lastKnownValue})
        lastKnownValue = currentVal
    end
    while collectLog[1] and (now - collectLog[1].t) > 60 do
        table.remove(collectLog, 1)
    end
    if #collectLog == 0 then return 0 end
    local total = 0
    for _, e in pairs(collectLog) do total = total + e.v end
    local window = math.min(now - collectLog[1].t, 60)
    if window < 1 then return 0 end
    return math.floor((total / window) * 60)
end

