uptimeValue.Text, uptimeValue.TextColor3, uptimeValue.TextSize, uptimeValue.Font, uptimeValue.TextXAlignment = "00:00", C.amber, 13, Enum.Font.Code, Enum.TextXAlignment.Right
uptimeValue.Parent = uptimeRow

task.spawn(function()
    while task.wait(1) do
        if isLooping then
            local elapsed = tick() - startTime
            uptimeValue.Text = string.format("%02d:%02d:%02d", math.floor(elapsed/3600), math.floor((elapsed%3600)/60), math.floor(elapsed%60))
        end
    end
end)

local sep = Instance.new("Frame")
sep.Size, sep.Position, sep.BackgroundColor3, sep.BackgroundTransparency, sep.BorderSizePixel, sep.LayoutOrder = UDim2.new(0.9,0,0,1), UDim2.new(0.05,0,0,0), C.amberDim, 0.70, 0, 8
sep.Parent = content

local invHeader = Instance.new("Frame")
invHeader.Size, invHeader.BackgroundTransparency, invHeader.LayoutOrder = UDim2.new(1,0,0,18), 1, 9
invHeader.Parent = content

local invTitle = Instance.new("TextLabel")
invTitle.Size, invTitle.BackgroundTransparency = UDim2.new(0.5,0,1,0), 1
invTitle.Text, invTitle.TextColor3, invTitle.TextSize, invTitle.Font, invTitle.TextXAlignment = "INVENTORY", C.amberGlow, 9, Enum.Font.GothamBold, Enum.TextXAlignment.Left
invTitle.Parent = invHeader

local invScroll = Instance.new("ScrollingFrame")
invScroll.Size, invScroll.BackgroundColor3, invScroll.BackgroundTransparency, invScroll.BorderSizePixel = UDim2.new(1,0,1,-254), C.card, 0.30, 0
invScroll.ScrollBarThickness, invScroll.ScrollBarImageColor3, invScroll.AutomaticCanvasSize, invScroll.CanvasSize, invScroll.LayoutOrder = 2, C.amberDim, Enum.AutomaticSize.Y, UDim2.new(0,0,0,0), 10
invScroll.Parent = content; corner(invScroll, 8); stroke(invScroll, C.border, 1, 0.5)

local invLayout = Instance.new("UIListLayout")
invLayout.SortOrder, invLayout.Padding = Enum.SortOrder.LayoutOrder, UDim.new(0,3)
invLayout.Parent = invScroll; pad(invScroll, 5,5,5,5)

local function refreshInventory()
    for _, c in ipairs(invScroll:GetChildren()) do if c:IsA("Frame") or c:IsA("TextLabel") then c:Destroy() end end
    local inv = player:FindFirstChild("inventory")
    if not inv then
        local n = Instance.new("TextLabel"); n.Size, n.BackgroundTransparency = UDim2.new(1,0,0,20), 1
        n.Text, n.TextColor3, n.TextSize, n.Font = "No inventory found", C.textMuted, 10, Enum.Font.Gotham; n.Parent = invScroll; return
    end
    local items = inv:GetChildren()
    if #items == 0 then
        local e = Instance.new("TextLabel"); e.Size, e.BackgroundTransparency = UDim2.new(1,0,0,20), 1
        e.Text, e.TextColor3, e.TextSize, e.Font = "Empty", C.textMuted, 10, Enum.Font.Gotham; e.Parent = invScroll
    else
        for i, item in ipairs(items) do
            if item:IsA("ValueBase") then
                local row = Instance.new("Frame")
                row.Size, row.BackgroundColor3, row.BackgroundTransparency, row.LayoutOrder = UDim2.new(1,0,0,20), C.raised, 0.45, i
                row.Parent = invScroll; corner(row, 5)
                local stripe = Instance.new("Frame")
                stripe.Size, stripe.BackgroundColor3, stripe.BackgroundTransparency, stripe.BorderSizePixel = UDim2.new(0,2,1,-4), C.amberDim, 0.25, 0
                stripe.Position = UDim2.new(0,0,0,2); stripe.Parent = row; corner(stripe, 1)
                local n = Instance.new("TextLabel")
                n.Size, n.Position, n.BackgroundTransparency = UDim2.new(0.60,-4,1,0), UDim2.new(0,8,0,0), 1
                n.Text, n.TextColor3, n.TextSize, n.Font, n.TextXAlignment = item.Name, C.textSec, 10, Enum.Font.Gotham, Enum.TextXAlignment.Left
                n.Parent = row
                local v = Instance.new("TextLabel")
                v.Size, v.Position, v.BackgroundTransparency = UDim2.new(0.40,0,1,0), UDim2.new(0.60,0,0,0), 1
                v.TextColor3, v.TextSize, v.Font, v.TextXAlignment = C.amber, 10, Enum.Font.Code, Enum.TextXAlignment.Right
                v.Text = formatSuffix(item.Value); v.Parent = row
                item:GetPropertyChangedSignal("Value"):Connect(function() if v and v.Parent then v.Text = formatSuffix(item.Value) end end)
            end
        end
    end
end

local invConn = player:WaitForChild("inventory", 10)
if invConn then
    invConn.ChildAdded:Connect(function() task.defer(refreshInventory) end)
    invConn.ChildRemoved:Connect(function() task.defer(refreshInventory) end)
end
task.defer(refreshInventory)

RunService.Heartbeat:Connect(function() if isLooping then updateDiscord() end end)

local dragging, dragStart, startPos, dragInput
header.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging, dragStart, startPos = true, i.Position, main.Position
        shadow.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset - 12, startPos.Y.Scale, startPos.Y.Offset - 12)
        i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then dragging = false end end)
    end
end)
header.InputChanged:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then dragInput = i end
end)
UserInputService.InputChanged:Connect(function(i)
    if dragging and i == dragInput then
        local d = i.Position - dragStart
        local newPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
        main.Position = newPos
        shadow.Position = UDim2.new(newPos.X.Scale, newPos.X.Offset - 12, newPos.Y.Scale, newPos.Y.Offset - 12)
    end
end)
task.delay(1, startFarming)

task.wait(1)

