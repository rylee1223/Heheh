-- ============================================================
--  CASE FARMER GUI  —  Config
local DEFAULT_CASE = 10   -- Which case to start on (1–10)
-- ============================================================

local CONFIG = {
    -- Bot token and channel (shared)
    BOT_TOKEN = "GITHUB_PLACEHOLDER", -- Loader replaces this securely
    CHANNEL_ID = "1517885492258013184",

    -- How often to update Discord messages (in minutes)
    UPDATE_INTERVAL = 5,

    -- 4 Player slots — fill in EXACT Roblox USERNAME + their message ID
    PLAYERS = {
        {USERNAME = "Build3r_MAGIC2012", MESSAGE_ID = "1518758643166875681"},
        {USERNAME = "odtgPixelTiger", MESSAGE_ID = "1518758669922336828"},
        {USERNAME = "qak_HazeMoonHD5705", MESSAGE_ID = "1518758690235224208"},
        {USERNAME = "dimdam457secholder", MESSAGE_ID = "1518758703824633916"},
    },
}

local Players         = game:GetService("Players")
local RunService      = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualUser     = game:GetService("VirtualUser")
local HttpService     = game:GetService("HttpService")

local player    = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Remove old GUI
if playerGui:FindFirstChild("CaseFarmingGUI") then
    playerGui.CaseFarmingGUI:Destroy()
end

-- ── State ────────────────────────────────────────────────────
local selectedCase   = DEFAULT_CASE
local isLooping      = false
local loopConnection = nil
local dropdownOpen   = false
local startTime      = 0
local lastUpdateTime = 0
local casesOpened    = 0

-- ── Discord Slot Finder ──────────────────────────────────────
local mySlot = nil
for _, slot in pairs(CONFIG.PLAYERS) do
    if string.lower(slot.USERNAME) == string.lower(player.Name) then
        mySlot = slot
        break
    end
end
local linkedMessageId = (mySlot and mySlot.MESSAGE_ID ~= "") and mySlot.MESSAGE_ID or nil

-- ── Helpers ──────────────────────────────────────────────────
local function getPrompt(num)
    local cases = workspace["World Building"]:FindFirstChild("Cases")
    if not cases then return nil end
    local folder = cases:FindFirstChild("Case_" .. num)
    if not folder then return nil end
    local base = folder:FindFirstChild("Base")
    if not base then return nil end
    return base:FindFirstChild("ProximityPrompt")
end

local function firePrompt(prompt)
    prompt.HoldDuration = 0
    prompt.Enabled = true
    casesOpened = casesOpened + 1
    if fireproximityprompt then
        fireproximityprompt(prompt)
    else
        prompt:InputHoldBegin()
        task.wait()
        prompt:InputHoldEnd()
    end
end

-- ── Discord Functions ────────────────────────────────────────
local function discordRequest(method, endpoint, body)
    if CONFIG.BOT_TOKEN == "" or CONFIG.BOT_TOKEN == "GITHUB_PLACEHOLDER" or CONFIG.CHANNEL_ID == "" then return nil, "Missing Token" end
    local req = (syn and syn.request) or (http and http.request) or http_request or request
    if not req then return nil, "No HTTP" end

    local success, response = pcall(function()
        return req({
            Url = "https://discord.com/api/v10" .. endpoint,
            Method = method,
            Headers = {
                ["Authorization"] = "Bot " .. CONFIG.BOT_TOKEN,
                ["Content-Type"]  = "application/json",
            },
            Body = body and HttpService:JSONEncode(body) or nil,
        })
    end)

    if not success then return nil, "Crash" end
    if response and response.StatusCode then
        if response.StatusCode >= 200 and response.StatusCode < 300 then
            return true, nil
        else
            return nil, "API Error " .. tostring(response.StatusCode)
        end
    end
    return nil, "No response"
end

local function getInventoryString()
    local invFolder = player:FindFirstChild("inventory")
    if not invFolder then return "No Inventory Found" end
    local str = ""
    for _, item in pairs(invFolder:GetChildren()) do
        str = str .. item.Name .. ": " .. tostring(item.Value) .. "\n"
    end
    if str == "" then return "Empty" end
    if #str > 1000 then return str:sub(1, 997) .. "..." end
    return str
end

local function updateDiscord()
    if CONFIG.BOT_TOKEN == "GITHUB_PLACEHOLDER" or not mySlot or not linkedMessageId then return end
    local now = tick()
    if now - lastUpdateTime < (CONFIG.UPDATE_INTERVAL * 60) then return end
    lastUpdateTime = now

    local elapsed = now - startTime
    local uptimeStr = string.format("%02d:%02d", math.floor(elapsed/60), math.floor(elapsed%60))

    local slotIndex = "?"
    for i, s in pairs(CONFIG.PLAYERS) do
        if s == mySlot then slotIndex = tostring(i) break end
    end

    local embedData = {
        content = " ",
        embeds = {{
            title  = "📦  Case Farmer — Player " .. slotIndex .. " Live",
            color  = 3447003,
            fields = {
                {name = "👤 Player",      value = "```" .. player.Name .. "```", inline = true},
                {name = "💼 Cases Opened", value = "```" .. tostring(casesOpened) .. "```", inline = true},
                {name = "🎯 Case Type",   value = "```Case " .. tostring(selectedCase) .. "```", inline = true},
                {name = "📡 Status",      value = "```" .. (isLooping and "Farming" or "Idle") .. "```", inline = true},
                {name = "⏱ Uptime",      value = "```" .. uptimeStr .. "```", inline = true},
                {name = "🎒 Inventory",   value = "```\n" .. getInventoryString() .. "```", inline = false},
            },
            footer    = {text = "Slot " .. slotIndex .. " of 4  •  Updates every " .. CONFIG.UPDATE_INTERVAL .. " min"},
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
            thumbnail = {
                url = "https://www.roblox.com/headshot-thumbnail/image?userId="
                    .. player.UserId .. "&width=420&height=420&format=png"
            },
        }}
    }

    task.spawn(function()
        discordRequest("PATCH", "/channels/" .. CONFIG.CHANNEL_ID .. "/messages/" .. linkedMessageId, embedData)
    end)
end

-- ── Palette ───────────────────────────────────────────────────
local C = {
    bg         = Color3.fromRGB(18, 18, 22),
    surface    = Color3.fromRGB(26, 26, 32),
    elevated   = Color3.fromRGB(34, 34, 42),
    border     = Color3.fromRGB(55, 55, 68),
    accent     = Color3.fromRGB(99, 130, 255),
    accentDim  = Color3.fromRGB(60, 85, 180),
    danger     = Color3.fromRGB(200, 65, 65),
    success    = Color3.fromRGB(72, 199, 128),
    textPri    = Color3.fromRGB(230, 230, 238),
    textSec    = Color3.fromRGB(130, 130, 148),
    textMuted  = Color3.fromRGB(80, 80, 96),
}

local function stroke(parent, color, thickness, trans)
    local s = Instance.new("UIStroke")
    s.Color       = color or C.border
    s.Thickness   = thickness or 1
    s.Transparency = trans or 0
    s.Parent      = parent
    return s
end

local function corner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = parent
    return c
end

