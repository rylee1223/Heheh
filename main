dropBtn.Size, dropBtn.BackgroundColor3, dropBtn.Text, dropBtn.TextColor3, dropBtn.TextSize, dropBtn.Font, dropBtn.LayoutOrder = UDim2.new(1, 0, 0, 26), C.surface, "Select Case: " .. selectedCase, C.textPri, 11, Enum.Font.Gotham, 2
