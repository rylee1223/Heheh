local sep = Instance.new("Frame")
sep.Size, sep.BackgroundColor3, sep.BackgroundTransparency, sep.LayoutOrder = UDim2.new(1, 0, 0, 1), C.border, 0.5, 6
sep.Parent = content

local invTitle = Instance.new("TextLabel")
invTitle.Size, invTitle.BackgroundTransparency, invTitle.Text, invTitle.TextColor3, invTitle.TextSize, invTitle.Font, invTitle.TextXAlignment, invTitle.LayoutOrder = UDim2.new(1, 0, 0, 16), 1, "INVENTORY", C.textMuted, 9, Enum.Font.GothamBold, Enum.TextXAlignment.Left, 7
invTitle.Parent = content

local invScroll = Instance.new("ScrollingFrame")
invScroll.Size, invScroll.BackgroundColor3, invScroll.BackgroundTransparency, invScroll.BorderSizePixel, invScroll.ScrollBarThickness, invScroll.ScrollBarImageColor3, invScroll.AutomaticCanvasSize, invScroll.CanvasSize, invScroll.LayoutOrder = UDim2.new(1, 0, 1, -180), C.surface, 0.5, 0, 2, C.accentDim, Enum.AutomaticSize.Y, UDim2.new(0, 0, 0, 0), 8
invScroll.Parent = content; corner(invScroll, 5); stroke(invScroll, C.border, 1, 0.5)

local invLayout = Instance.new("UIListLayout")
invLayout.SortOrder, invLayout.Padding = Enum.SortOrder.LayoutOrder, UDim.new(0, 2)
invLayout.Parent = invScroll

local invPad = Instance.new("UIPadding")
invPad.PaddingTop, invPad.PaddingBottom, invPad.PaddingLeft, invPad.PaddingRight = UDim.new(0, 3), UDim.new(0, 3), UDim.new(0, 5), UDim.new(0, 5)
invPad.Parent = invScroll

local function refreshInventory()
    for _, c in ipairs(invScroll:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
    local inv = player:FindFirstChild("inventory")
    if not inv then
        local n = Instance.new("TextLabel"); n.Size, n.BackgroundTransparency, n.Text, n.TextColor3, n.TextSize, n.Font = UDim2.new(1, 0, 0, 16), 1, "No inventory found", C.textMuted, 10, Enum.Font.Gotham; n.Parent = invScroll; return
    end
    local items = inv:GetChildren()
    if #items == 0 then
        local e = Instance.new("TextLabel"); e.Size, e.BackgroundTransparency, e.Text, e.TextColor3, e.TextSize, e.Font = UDim2.new(1, 0, 0, 16), 1, "Inventory is empty", C.textMuted, 10, Enum.Font.Gotham; e.Parent = invScroll
    else
        for i, item in ipairs(items) do
            if item:IsA("ValueBase") then
                local row = Instance.new("Frame"); row.Size, row.BackgroundColor3, row.BackgroundTransparency, row.LayoutOrder = UDim2.new(1, 0, 0, 18), C.elevated, 0.4, i; row.Parent = invScroll; corner(row, 3)
                local n = Instance.new("TextLabel"); n.Size, n.BackgroundTransparency, n.Text, n.TextColor3, n.TextSize, n.Font, n.TextXAlignment = UDim2.new(0.6, 0, 1, 0), 1, item.Name, C.textPri, 10, Enum.Font.Gotham, Enum.TextXAlignment.Left; n.Parent = row
                local v = Instance.new("TextLabel"); v.Size, v.Position, v.BackgroundTransparency = UDim2.new(0.4, 0, 1, 0), UDim2.new(0.6, 0, 0, 0), 1
                v.Text, v.TextColor3, v.TextSize, v.Font, v.TextXAlignment = formatSuffix(item.Value), C.accent, 10, Enum.Font.Code, Enum.TextXAlignment.Right; v.Parent = row
                item:GetPropertyChangedSignal("Value"):Connect(function() if v and v.Parent then v.Text = formatSuffix(item.Value) end end)
            end
        end
    end
end

local invConn = player:WaitForChild("inventory", 10)
if invConn then
    invConn.ChildAdded:Connect(function() task.defer(refreshInventory) end)
    invConn.ChildRemoved:Connect(function() task.defer(refreshInventory) end)
end
task.defer(refreshInventory)

-- ── Discord Update Loop ──────────────────────────────────────
RunService.Heartbeat:Connect(function() if isLooping then updateDiscord() end end)

-- ── Dragging ─────────────────────────────────────────────────
local dragging, dragStart, startPos
header.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging, dragStart, startPos = true, i.Position, main.Position
        i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then dragging = false end end)
    end
end)
header.InputChanged:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then dragInput = i end end)
UserInputService.InputChanged:Connect(function(i)
    if dragging and i == dragInput then
        local d = i.Position - dragStart
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
    end
end)

-- ── AUTO START ───────────────────────────────────────────────
task.delay(1, startFarming)
