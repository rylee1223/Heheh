dropLayout.SortOrder, dropLayout.Parent = Enum.SortOrder.LayoutOrder, dropList

for i = 1, 10 do
    local btn = Instance.new("TextButton")
    btn.Size, btn.BackgroundColor3, btn.BackgroundTransparency, btn.Text, btn.TextColor3, btn.TextSize, btn.Font, btn.LayoutOrder = UDim2.new(1, 0, 0, 19), C.surface, 0.5, "Case " .. i, C.textSec, 10, Enum.Font.Gotham, i
    btn.Parent = dropList
    btn.MouseButton1Click:Connect(function()
        selectedCase = i; dropBtn.Text = "Select Case: " .. i; dropList.Visible = false; dropdownOpen = false
    end)
end
dropBtn.MouseButton1Click:Connect(function() dropdownOpen = not dropdownOpen; dropList.Visible = dropdownOpen end)

-- ── Farm Button ──────────────────────────────────────────────
local farmFrame = Instance.new("Frame")
farmFrame.Size, farmFrame.BackgroundColor3, farmFrame.LayoutOrder = UDim2.new(1, 0, 0, 30), C.accent, 4
farmFrame.Parent = content; corner(farmFrame, 5)

local farmBtn = Instance.new("TextButton")
farmBtn.Size, farmBtn.BackgroundTransparency, farmBtn.Text, farmBtn.TextColor3, farmBtn.TextSize, farmBtn.Font = UDim2.new(1, 0, 1, 0), 1, "▶ START FARMING", Color3.new(1,1,1), 12, Enum.Font.GothamBold
farmBtn.Parent = farmFrame

local function startFarming()
    if isLooping then return end
    isLooping = true; farmBtn.Text, farmFrame.BackgroundColor3 = "■ STOP FARMING", C.danger
    startTime, casesOpened, lastUpdateTime = tick(), 0, 0
    farmConnection = RunService.Heartbeat:Connect(function() firePrompt(getPrompt(selectedCase)) end)
end

local function stopFarming()
    if not isLooping then return end
    isLooping = false; farmBtn.Text, farmFrame.BackgroundColor3 = "▶ START FARMING", C.accent
    if farmConnection then farmConnection:Disconnect(); farmConnection = nil end
end

farmBtn.MouseButton1Click:Connect(function() if isLooping then stopFarming() else startFarming() end end)

-- ── Stored Stat Display ──────────────────────────────────────
local statRow = Instance.new("Frame")
statRow.Size, statRow.BackgroundColor3, statRow.LayoutOrder = UDim2.new(1, 0, 0, 26), C.surface, 5
statRow.Parent = content; corner(statRow, 5); stroke(statRow, C.border, 1, 0.5)

local statIcon = Instance.new("TextLabel")
statIcon.Size, statIcon.BackgroundTransparency, statIcon.Text, statIcon.TextSize, statIcon.Font = UDim2.new(0, 24, 1, 0), 1, "💾", 13, Enum.Font.Gotham
statIcon.Parent = statRow

local statLabel = Instance.new("TextLabel")
statLabel.Size, statLabel.Position, statLabel.BackgroundTransparency = UDim2.new(0.35, -24, 1, 0), UDim2.new(0, 24, 0, 0), 1
statLabel.Text, statLabel.TextColor3, statLabel.TextSize, statLabel.Font, statLabel.TextXAlignment = "STORED", C.textSec, 11, Enum.Font.GothamBold, Enum.TextXAlignment.Left
statLabel.Parent = statRow

local statValue = Instance.new("TextLabel")
statValue.Size, statValue.Position, statValue.BackgroundTransparency = UDim2.new(0.65, 0, 1, 0), UDim2.new(0.35, 0, 0, 0), 1
statValue.Text, statValue.TextColor3, statValue.TextSize, statValue.Font, statValue.TextXAlignment = "Loading...", C.accent, 12, Enum.Font.Code, Enum.TextXAlignment.Right
statValue.Parent = statRow

-- Live Stored Updater
task.spawn(function()
    local stats = player:WaitForChild("playerstats", 15)
    if not stats then statValue.Text = "N/A"; return end
    local stored = stats:WaitForChild("Stored", 15)
    if not stored then statValue.Text = "N/A"; return end
    while task.wait(0.5) do
        if stored.Parent then statValue.Text = formatSuffix(tonumber(stored.Value) or 0) else break end
    end
end)

