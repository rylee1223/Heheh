farmBtn.Font                = Enum.Font.GothamBold
farmBtn.LayoutOrder         = 3
farmBtn.Parent              = content
corner(farmBtn, 6)

farmBtn.MouseButton1Click:Connect(function()
    isLooping = not isLooping
    if isLooping then
        farmBtn.Text = "Stop Farming"
        farmBtn.BackgroundColor3 = C.danger
        startTime = tick()
        casesOpened = 0
        lastUpdateTime = 0
        
        loopThread = task.spawn(function()
            while isLooping do
                local prompt = getPrompt(selectedCase)
                firePrompt(prompt)
                task.wait(0.5)
            end
        end)
    else
        farmBtn.Text = "Start Farming"
        farmBtn.BackgroundColor3 = C.accent
        if loopThread then task.cancel(loopThread) end
    end
end)

