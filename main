local sel = DEFAULT_CASE
local loop = false
local conn = nil
local opened = 0
local startT = 0
local lastDiscord = 0

-- Slot stuff
local mySlot, linkedMsg
for i, s in ipairs(CONFIG.PLAYERS) do
    if s.USERNAME:lower() == player.Name:lower() then mySlot = s; break end
end
if mySlot and mySlot.MESSAGE_ID ~= "" then linkedMsg = mySlot.MESSAGE_ID end

-- ═══════════════════════════════════════════════════════════
--  PRE-CACHED PROMPT (ZERO-LOOKUP FARMING)
-- ═══════════════════════════════════════════════════════════
local prompt = nil

local function cachePrompt()
    local wb = workspace:FindFirstChild("World Building")
    if not wb then prompt = nil; return end
    local cs = wb:FindFirstChild("Cases")
    if not cs then prompt = nil; return end
    local cf = cs:FindFirstChild("Case_" .. sel)
    if not cf then prompt = nil; return end
    local bs = cf:FindFirstChild("Base")
    if not bs then prompt = nil; return end
    prompt = bs:FindFirstChild("ProximityPrompt")
    if prompt then
        prompt.HoldDuration = 0
        prompt.MaxActivationDistance = 9e9
        prompt.Enabled = true
    end
end

-- Lightning fast fire
local firepp = fireproximityprompt
local function fire()
    if not prompt or prompt.Parent == nil then 
        cachePrompt(); 
        if not prompt then return end 
    end
    -- Count attempt
    opened = opened + 1
    
    if firepp then
        firepp(prompt)
    else
        -- Fallback instantly
        prompt:InputHoldBegin()
        prompt:InputHoldEnd()
    end
end

-- ═══════════════════════════════════════════════════════════
--  ROBUST INVENTORY LOGIC
-- ═══════════════════════════════════════════════════════════
local function fmt(n)
    n = tonumber(n) or 0
    if n >= 1e12 then return ("%.2fT"):format(n/1e12)
    elseif n >= 1e9 then return ("%.2fB"):format(n/1e9)
    elseif n >= 1e6 then return ("%.2fM"):format(n/1e6)
    elseif n >= 1e3 then return ("%.2fK"):format(n/1e3)
    else return tostring(math.floor(n)) end
end

local function getInvData()
    local pinv = player:FindFirstChild("inventory") or player:FindFirstChild("Inventory")
    if not pinv then return "No Inv Folder" end
    local t = {}
    
    local function scan(parent)
        for _, it in ipairs(parent:GetChildren()) do
            if (it:IsA("IntValue") or it:IsA("NumberValue")) and it.Value > 0 then
                t[#t+1] = it.Name .. ": " .. fmt(it.Value)
            elseif it:IsA("Folder") then
                scan(it)
            end
        end
    end
    
    scan(pinv)
    return #t > 0 and table.concat(t, "\n") or "Empty"
end

-- ═══════════════════════════════════════════════════════════
--  DISCORD (NON-BLOCKING DEDICATED THREAD)
-- ═══════════════════════════════════════════════════════════
local function updateDiscord()
    if not linkedMsg then return end
    
    task.spawn(function()
        local invStr = getInvData()
        
        local pstats = player:FindFirstChild("playerstats")
        local stored = pstats and pstats:FindFirstChild("Stored")
        local sv = stored and tonumber(stored.Value) or 0
        
        local elapsed = tick() - startT
        local slots = "?"
        for i, s in ipairs(CONFIG.PLAYERS) do if s == mySlot then slots = tostring(i); break end end
        
        local body = {
            content = " ",
            embeds = {{
                title = "📦 Case Farmer — Player " .. slots .. " Live",
                color = 3447003,
                fields = {
                    {name="👤 Player", value="```"..player.Name.."```", inline=true},
                    {name="💼 Opened", value="```"..tostring(opened).."```", inline=true},
                    {name="🎯 Case", value="```Case "..tostring(sel).."```", inline=true},
                    {name="📡 Status", value="```"..(loop and "Farming" or "Idle").."```", inline=true},
                    {name="⏱ Uptime", value="```"..("%02d:%02d"):format(elapsed/60, elapsed%60).."```", inline=true},
                    {name="💾 Stored", value="```"..tostring(sv - sv%1).." ("..fmt(sv)..")```", inline=true},
                    {name="🎒 Inventory", value="```\n"..invStr.."```", inline=false},
                },
                footer = {text = "Slot " .. slots .. " of 4"},
                timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
                thumbnail = {url = "https://www.roblox.com/headshot-thumbnail/image?userId="..player.UserId.."&width=420&height=420&format=png"}
            }}
        }
        
        local req = syn and syn.request or http and http.request or http_request or request
        if req then
            req({
                Url = "https://discord.com/api/v10/channels/" .. CONFIG.CHANNEL_ID .. "/messages/" .. linkedMsg,
                Method = "PATCH",
                Headers = {
                    ["Authorization"] = "Bot " .. CONFIG.BOT_TOKEN,
                    ["Content-Type"] = "application/json"
                },
                Body = HS:JSONEncode(body)
            })
        end
    end)
end

-- Dedicated thread for Discord updates
task.spawn(function()
    while task.wait(CONFIG.UPDATE_INTERVAL * 60) do
        if loop then updateDiscord() end
    end
end)

