-- ── Farm Button ──────────────────────────────────────────────
local farmBtn = Instance.new("TextButton")
farmBtn.Size                = UDim2.new(1, 0, 0, 36)
farmBtn.BackgroundColor3    = C.accent
farmBtn.Text                = "Start Farming"
farmBtn.TextColor3          = Color3.new(1,1,1)
