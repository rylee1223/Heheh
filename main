-- Time Stat Live Updater
task.spawn(function()
    local statsFolder = player:WaitForChild("playerstats", 10)
    if statsFolder then
        local timeStat = statsFolder:WaitForChild("Time", 10)
        if timeStat then
            local function updateTime()
                timeValueLabel.Text = formatNumber(timeStat.Value)
            end
            timeStat.Changed:Connect(updateTime)
            updateTime()
        else
            timeValueLabel.Text = "N/A"
        end
    else
        timeValueLabel.Text = "N/A"
    end
end)


