            local c = Color3.fromRGB(
                math.floor(190 + p * 65),
                math.floor(20  + p * 30),
                math.floor(50  + p * 60)
            )
            for _, b in pairs(bars) do b.BackgroundColor3 = c end
        else
            for _, b in pairs(bars) do b.BackgroundColor3 = Color3.fromRGB(80, 20, 40) end
        end
    end
end)

