-- ═══════════════════════════════════════════════════════════
--  60 CASES/SEC FARMING LOGIC
-- ═══════════════════════════════════════════════════════════
local function startFarming()
    if isLooping then return end
    isLooping = true
    farmBtn.Text = "■  STOP FARMING"
    farmBtn.TextColor3 = Color3.fromRGB(255, 200, 180)
    tween(farmFrame, {BackgroundColor3 = C.dangerDim, BackgroundTransparency = 0.05})
    stroke(farmFrame, C.danger, 1, 0.20)
    startTime, casesOpened, lastUpdateTime = tick(), 0, 0
    
    -- Runs every frame (~60 times/sec depending on FPS)
    farmConnection = RunService.Heartbeat:Connect(function()
        firePrompt(getPrompt(selectedCase))
    end)
end

local function stopFarming()
    if not isLooping then return end
    isLooping = false
    farmBtn.Text = "▶  START FARMING"
    farmBtn.TextColor3 = C.amber
    tween(farmFrame, {BackgroundColor3 = C.amberDark, BackgroundTransparency = 0.15})
    stroke(farmFrame, C.amber, 1, 0.30)
    if farmConnection then
        farmConnection:Disconnect()
        farmConnection = nil
    end
end

farmBtn.MouseButton1Click:Connect(function() if isLooping then stopFarming() else startFarming() end end)

