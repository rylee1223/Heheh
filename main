local function makeRow(parent, label, yPos)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1, -24, 0, 28)
    row.Position = UDim2.new(0, 12, 0, yPos)
    row.BackgroundTransparency = 1
    row.ZIndex = 3

    local bar = Instance.new("Frame", row)
    bar.Size = UDim2.new(0, 3, 0.55, 0)
    bar.Position = UDim2.new(0, 0, 0.225, 0)
    bar.BackgroundColor3 = Color3.fromRGB(200, 35, 60)
    bar.BorderSizePixel = 0
    bar.ZIndex = 4
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)

    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(0.44, 0, 1, 0)
    lbl.Position = UDim2.new(0, 12, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.Font = Enum.Font.GothamBold
    lbl.TextColor3 = Color3.fromRGB(160, 70, 100)
    lbl.TextSize = 11
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 4

    local val = Instance.new("TextLabel", row)
    val.Size = UDim2.new(0.52, 0, 1, 0)
    val.Position = UDim2.new(0.48, 0, 0, 0)
    val.BackgroundTransparency = 1
    val.Text = "—"
    val.Font = Enum.Font.Code
    val.TextColor3 = Color3.fromRGB(255, 215, 225)
    val.TextSize = 12
    val.TextXAlignment = Enum.TextXAlignment.Left
    val.ZIndex = 4

    return val, bar
end

