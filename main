--// BEAM
local beam, att0
local function setupBeam()
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp  = char:WaitForChild("HumanoidRootPart", 10)
    if not hrp then return end
    if att0 and att0.Parent then att0:Destroy() end
    if beam and beam.Parent then beam:Destroy() end
    att0 = Instance.new("Attachment", hrp)
    beam = Instance.new("Beam", hrp)
    beam.Attachment0 = att0
    beam.Width0, beam.Width1 = 0.07, 0.07
    beam.FaceCamera    = true
    beam.Enabled       = false
    beam.LightEmission = 1
    beam.LightInfluence = 0
    beam.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   Color3.fromRGB(255, 90,  110)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 15,  55)),
        ColorSequenceKeypoint.new(1,   Color3.fromRGB(255, 90,  110))
    })
    beam.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0,   0.5),
        NumberSequenceKeypoint.new(0.5, 0.05),
        NumberSequenceKeypoint.new(1,   0.5)
    })
end
setupBeam()
player.CharacterAdded:Connect(function() task.wait(0.5) setupBeam() end)

--// ESP — CLOSEST ONLY
local espTarget, espSphere, espBox, espBill, espThread = nil, nil, nil, nil, nil

local function clearESP()
    if espThread then task.cancel(espThread) espThread = nil end
    if espSphere and espSphere.Parent then espSphere:Destroy() end
    if espBox    and espBox.Parent    then espBox:Destroy()    end
    if espBill   and espBill.Parent   then espBill:Destroy()   end
    espSphere, espBox, espBill, espTarget = nil, nil, nil, nil
end

local function applyESP(part)
    if espTarget == part then return end
    clearESP()
    if not part then return end
    espTarget = part

    local avg   = (part.Size.X + part.Size.Y + part.Size.Z) / 3
    local baseR = avg * CONFIG.ESP_SPHERE_SCALE

    espSphere = Instance.new("SphereHandleAdornment", part)
    espSphere.Adornee      = part
    espSphere.AlwaysOnTop  = true
    espSphere.ZIndex       = 5
    espSphere.Color3       = Color3.fromRGB(255, 30, 60)
    espSphere.Transparency = 0.25
    espSphere.Radius       = baseR

    espBox = Instance.new("SelectionBox", part)
    espBox.Adornee             = part
    espBox.Color3              = Color3.fromRGB(255, 25, 55)
    espBox.LineThickness       = 0.055
    espBox.SurfaceTransparency = 0.82
    espBox.SurfaceColor3       = Color3.fromRGB(255, 25, 55)

    espBill = Instance.new("BillboardGui", part)
    espBill.AlwaysOnTop  = true
    espBill.Size         = UDim2.new(0, 95, 0, 32)
    espBill.StudsOffset  = Vector3.new(0, avg / 2 + 2.2, 0)

    local bg = Instance.new("Frame", espBill)
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Color3.fromRGB(8, 4, 14)
    bg.BackgroundTransparency = 0.2
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 8)
    Instance.new("UIStroke", bg).Color = Color3.fromRGB(160, 15, 45)

    local topTxt = Instance.new("TextLabel", bg)
    topTxt.Size = UDim2.new(1, 0, 0.5, 0)
    topTxt.BackgroundTransparency = 1
    topTxt.Text = "GIFT BOX"
    topTxt.Font = Enum.Font.GothamBold
    topTxt.TextColor3 = Color3.fromRGB(255, 130, 155)
    topTxt.TextSize = 10

    local distTxt = Instance.new("TextLabel", bg)
    distTxt.Size = UDim2.new(1, 0, 0.5, 0)
    distTxt.Position = UDim2.new(0, 0, 0.5, 0)
    distTxt.BackgroundTransparency = 1
    distTxt.Text = "— studs"
    distTxt.Font = Enum.Font.Code
    distTxt.TextColor3 = Color3.fromRGB(255, 200, 215)
    distTxt.TextSize = 10
    distTxt.Name = "DistLabel"

    espThread = task.spawn(function()
        local t = 0
        while espSphere and espSphere.Parent do
            t = t + 0.055
            local p = (math.sin(t * CONFIG.ESP_PULSE_SPEED) + 1) / 2
            espSphere.Radius       = baseR * (1 + CONFIG.ESP_PULSE_AMOUNT * p)
            espSphere.Color3       = Color3.fromRGB(255, math.floor(8+p*55), math.floor(15+p*55))
            espSphere.Transparency = 0.18 + p * 0.38
            if espBox and espBox.Parent then
                espBox.Color3 = Color3.fromRGB(255, math.floor(8+p*45), math.floor(15+p*45))
            end
            local c = player.Character
            if c and espBill and espBill.Parent then
                local hrp = c:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dl = bg:FindFirstChild("DistLabel")
                    if dl then
                        dl.Text = math.floor((hrp.Position - part.Position).Magnitude) .. " studs"
                    end
                end
            end
            task.wait(0.03)
        end
    end)
end

--// HELPERS
local function tryJump(hum, hrp, target)
    if not target or not hum or not hrp then return end
    if (hrp.Position - target.Position).Magnitude > CONFIG.JUMP_DISTANCE
       and tick() - jumpCooldown > CONFIG.JUMP_COOLDOWN then
        hum.Jump   = true
        jumpCooldown = tick()
    end
end

local function getClosest(hrp)
    local closest, minDist = nil, math.huge
    for _, v in pairs(giftFolder:GetChildren()) do
        if v:IsA("BasePart") then
            local d = (hrp.Position - v.Position).Magnitude
            if d < minDist then minDist = d; closest = v end
        end
    end
    return closest, minDist
end

--// MAIN LOOP
RunService.Heartbeat:Connect(function()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    local now = tick()
    local closest, minDist = getClosest(hrp)

    if espEnabled then
        if closest then applyESP(closest) else clearESP() end
    else
        if espTarget then clearESP() end
    end

    if not enabled then return end

    local elapsed    = now - startTime
    local currentVal = getStatValue()
    local collected  = currentVal - startVal
    local rate       = logCollection(currentVal)

    statusVal.Text = closest and "FARMING" or "SEARCHING"
    gainedVal.Text = tostring(collected)
    totalVal.Text  = tostring(currentVal)
    timeVal.Text   = string.format("%02d:%02d", math.floor(elapsed/60), math.floor(elapsed%60))
    distVal.Text   = closest and string.format("%.1f studs", minDist) or "—"
    rateVal.Text   = rate > 0 and (tostring(rate) .. " / min") or "calculating..."

    currentTarget = closest
    updateDiscord(collected, rate, elapsed)

    if closest then
        local dir = (closest.Position - hrp.Position).Unit
        hum:MoveTo(closest.Position + dir * CONFIG.OVERSHOOT)
        tryJump(hum, hrp, closest)

        if beam then
            local tAtt = closest:FindFirstChild("TargetAtt")
            if not tAtt then
                tAtt = Instance.new("Attachment", closest)
                tAtt.Name = "TargetAtt"
            end
            beam.Attachment1 = tAtt
            beam.Enabled = true
        end

        if now - lastCheckTime > CONFIG.STUCK_CHECK_INTERVAL then
            local moved = (hrp.Position - lastPos).Magnitude
            if moved < CONFIG.STUCK_THRESHOLD then
                hum.Jump = true
                task.delay(0.4, function()
                    local c2 = player.Character
                    if c2 then
                        local h2 = c2:FindFirstChildOfClass("Humanoid")
                        if h2 then h2.Jump = true end
                    end
                end)
                if moved < CONFIG.STUCK_KILL_THRESHOLD then hum.Health = 0 end
            end
            lastPos      = hrp.Position
            lastCheckTime = now
        end
    else
        if beam then beam.Enabled = false end
    end
end)

--// AUTO START
local function startFarming()
    enabled        = true
    startVal       = getStatValue()
    startTime      = tick()
    collectLog     = {}
    lastKnownValue = startVal
    lastPos        = Vector3.zero
    lastCheckTime  = tick()
    lastUpdateTime = 0 -- Changed from tick() to 0 so it updates Discord instantly on start
    farmBtn.Text   = "■   STOP AUTO-FARM"
    farmBtn:FindFirstChildOfClass("UIStroke").Color = Color3.fromRGB(0, 200, 100)
    TweenService:Create(mainStroke, TweenInfo.new(0.3), {Color = Color3.fromRGB(0, 210, 110)}):Play()
end

farmBtn.MouseButton1Click:Connect(function()
    enabled = not enabled
    if enabled then
        startFarming()
    else
        farmBtn.Text = "▶   START AUTO-FARM"
        farmBtn:FindFirstChildOfClass("UIStroke").Color = Color3.fromRGB(220, 35, 65)
        if beam then beam.Enabled = false end
        statusVal.Text = "IDLE"
        gainedVal.Text = "0"
        totalVal.Text  = "—"
        timeVal.Text   = "00:00"
        distVal.Text   = "—"
        rateVal.Text   = "—"
        TweenService:Create(mainStroke, TweenInfo.new(0.3), {Color = Color3.fromRGB(200, 30, 60)}):Play()
    end
end)

espBtn.MouseButton1Click:Connect(function()
    espEnabled = not espEnabled
    espBtn.Text = espEnabled and "◈   ESP: ON" or "◈   ESP: OFF"
    espBtn:FindFirstChildOfClass("UIStroke").Color = espEnabled
        and Color3.fromRGB(255, 45, 85) or Color3.fromRGB(90, 28, 55)
    if not espEnabled then clearESP() end
end)

resetBtn.MouseButton1Click:Connect(function()
    local c = player.Character
    if c then
        local h = c:FindFirstChildOfClass("Humanoid")
        if h then h.Health = 0 end
    end
end)

--// TOGGLE
local toggle = Instance.new("TextButton", gui)
toggle.Size = UDim2.new(0, 46, 0, 46)
toggle.Position = UDim2.new(0, 14, 0.5, -23)
toggle.Text = "G"
toggle.TextSize = 19
toggle.Font = Enum.Font.GothamBold
toggle.TextColor3 = Color3.fromRGB(255, 130, 155)
toggle.BackgroundColor3 = Color3.fromRGB(10, 5, 16)
toggle.ZIndex = 10
Instance.new("UICorner", toggle).CornerRadius = UDim.new(1, 0)
local tStroke = Instance.new("UIStroke", toggle)
tStroke.Color = Color3.fromRGB(220, 30, 60)
tStroke.Thickness = 2

task.spawn(function()
    local t = 0
    while task.wait(0.04) do
        t = t + 0.04
        local p = (math.sin(t * 2.5) + 1) / 2
        tStroke.Color = Color3.fromRGB(
            math.floor(170 + p * 85),
            math.floor(12  + p * 28),
            math.floor(35  + p * 55)
        )
    end
end)

toggle.MouseButton1Click:Connect(function()
    main.Visible = not main.Visible
    shadow.Visible = main.Visible
    if main.Visible then
        main.Size = UDim2.new(0, 0, 0, 0)
        main.Position = UDim2.new(0.5, 0, 0.5, 0)
        TweenService:Create(main,
            TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 320, 0, 490),
            Position = UDim2.new(0.5, -160, 0.5, -245)
        }):Play()
        TweenService:Create(shadow,
            TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 360, 0, 530),
            Position = UDim2.new(0.5, -180, 0.5, -265)
        }):Play()
    end
end)

--// DRAGGING
local dragging, dragStart, dragPos
main.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or
       i.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = i.Position; dragPos = main.Position
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or
                     i.UserInputType == Enum.UserInputType.Touch) then
        local d = i.Position - dragStart
        main.Position   = UDim2.new(dragPos.X.Scale, dragPos.X.Offset + d.X, dragPos.Y.Scale, dragPos.Y.Offset + d.Y)
        shadow.Position = UDim2.new(dragPos.X.Scale, dragPos.X.Offset + d.X - 20, dragPos.Y.Scale, dragPos.Y.Offset + d.Y - 20)
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or
       i.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

--// AUTO OPEN + START
task.wait(0.3)
main.Visible   = true
shadow.Visible = true
main.Size      = UDim2.new(0, 0, 0, 0)
main.Position  = UDim2.new(0.5, 0, 0.5, 0)
TweenService:Create(main, TweenInfo.new(0.55, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
    Size     = UDim2.new(0, 320, 0, 490),
    Position = UDim2.new(0.5, -160, 0.5, -245)
}):Play()
TweenService:Create(shadow, TweenInfo.new(0.55, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
    Size     = UDim2.new(0, 360, 0, 530),
    Position = UDim2.new(0.5, -180, 0.5, -265)
}):Play()

task.delay(0.6, startFarming)

print("[GiftFarmer] Loaded — Slot: " .. (mySlot and player.Name or "NOT IN LIST"))
