local function setLoopUI(on)
    if on then
        loopBtn.Text             = "⏸  Stop Loop"
        loopBtn.BackgroundColor3 = C.accent
        loopBtn.BackgroundTransparency = 0.15
    else
        loopBtn.Text             = "▶  Start Loop"
        loopBtn.BackgroundColor3 = C.elevated
        loopBtn.BackgroundTransparency = 0.1
        stroke(loopBtn, C.border, 1, 0.5)
    end
end

makeDivider(DIV_Y)

