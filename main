-- Populate dropdown
for i = 1, 10 do
    local opt = Instance.new("TextButton")
    opt.Size             = UDim2.new(1, -10, 0, 28)
    opt.BackgroundColor3 = C.elevated
    opt.BackgroundTransparency = 0.3
    opt.Text             = "Case " .. i
    opt.TextColor3       = C.textPri
    opt.TextSize         = 13
    opt.Font             = Enum.Font.Gotham
    opt.BorderSizePixel  = 0
    opt.ZIndex           = 21
    opt.Parent           = dropdownList
    corner(opt, 6)

    opt.MouseEnter:Connect(function()
        opt.BackgroundColor3      = C.accent
        opt.BackgroundTransparency = 0.7
        opt.TextColor3            = Color3.new(1,1,1)
    end)
    opt.MouseLeave:Connect(function()
        opt.BackgroundColor3      = C.elevated
        opt.BackgroundTransparency = 0.3
        opt.TextColor3            = C.textPri
    end)
    opt.MouseButton1Click:Connect(function()
        selectedCase = i
        dropdownLabel.Text     = "Case " .. i
        dropdownList.Visible   = false
        dropdownOpen           = false
        chevron.Text           = "▾"
    end)
end

dropdownBtn.MouseButton1Click:Connect(function()
    dropdownOpen           = not dropdownOpen
    dropdownList.Visible   = dropdownOpen
    chevron.Text           = dropdownOpen and "▴" or "▾"
end)

-- ── Divider ───────────────────────────────────────────────────
local function makeDivider(yOff)
    local d = Instance.new("Frame")
    d.Size             = UDim2.new(1, -PAD*2, 0, 1)
    d.Position         = UDim2.new(0, PAD, 0, yOff)
    d.BackgroundColor3 = C.border
    d.BackgroundTransparency = 0.5
    d.BorderSizePixel  = 0
    d.Parent           = mainFrame
    return d
end

