local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Remove old GUI if it exists
if playerGui:FindFirstChild("CaseFarmingGUI") then
    playerGui.CaseFarmingGUI:Destroy()
end

-- State
local selectedCase = 10
local isLooping = false
local loopConnection = nil
local dropdownOpen = false

-- Get the prompt from a number
local function getPrompt(num)
    local cases = workspace["World Building"]:FindFirstChild("Cases")
    if not cases then return nil end
    local caseFolder = cases:FindFirstChild("Case_" .. num)
    if not caseFolder then return nil end
    local base = caseFolder:FindFirstChild("Base")
    if not base then return nil end
    return base:FindFirstChild("ProximityPrompt")
end

-- Fire once
local function fireOnce(statusLabel)
    local prompt = getPrompt(selectedCase)
    if not prompt then
        statusLabel.Text = "Case_" .. selectedCase .. " not found!"
        return
    end
    prompt.HoldDuration = 0
    prompt.Enabled = true
    if fireproximityprompt then
        fireproximityprompt(prompt)
    else
        prompt:InputHoldBegin()
        task.wait()
        prompt:InputHoldEnd()
    end
    statusLabel.Text = "Fired Case " .. selectedCase .. "!"
end

