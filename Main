-- Build dropdown options
for i = 1, 10 do
    local option = Instance.new("TextButton")
    option.Size = UDim2.new(1, -8, 0, 28)
    option.BackgroundColor3 = Color3.fromRGB(50, 50, 58)
    option.BackgroundTransparency = 0.1
    option.Text = "Case " .. i
    option.TextColor3 = Color3.fromRGB(215, 215, 222)
    option.TextSize = 13.5
    option.Font = Enum.Font.Gotham
    option.BorderSizePixel = 0
    option.ZIndex = 11
    option.Parent = dropdownList
    Instance.new("UICorner", option).CornerRadius = UDim.new(0, 6)

    option.MouseEnter:Connect(function()
        option.BackgroundColor3 = Color3.fromRGB(70, 70, 80)
    end)
    option.MouseLeave:Connect(function()
        option.BackgroundColor3 = Color3.fromRGB(50, 50, 58)
    end)

    option.MouseButton1Click:Connect(function()
        selectedCase = i
        dropdownBtn.Text = "Case " .. i .. "  ▼"
        dropdownList.Visible = false
        dropdownOpen = false
        statusLabel.Text = "Selected Case " .. i .. " | Anti-AFK Active"
    end)
end

-- Toggle dropdown
dropdownBtn.MouseButton1Click:Connect(function()
    dropdownOpen = not dropdownOpen
    dropdownList.Visible = dropdownOpen
    dropdownBtn.Text = dropdownOpen and ("Case " .. selectedCase .. "  ▲") or ("Case " .. selectedCase .. "  ▼")
end)

-- Fire Once Button
local fireBtn = Instance.new("TextButton")
fireBtn.Size = UDim2.new(1, -28, 0, 36)
fireBtn.Position = UDim2.new(0, 14, 0, 115)
fireBtn.BackgroundColor3 = Color3.fromRGB(58, 58, 68)
fireBtn.BackgroundTransparency = 0.1
fireBtn.Text = "Fire Once"
fireBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
fireBtn.TextSize = 14
fireBtn.Font = Enum.Font.GothamBold
fireBtn.BorderSizePixel = 0
fireBtn.Parent = mainFrame
Instance.new("UICorner", fireBtn).CornerRadius = UDim.new(0, 7)

fireBtn.MouseButton1Click:Connect(function()
    fireOnce(statusLabel)
end)

-- Loop Toggle Button
local loopBtn = Instance.new("TextButton")
loopBtn.Size = UDim2.new(1, -28, 0, 36)
loopBtn.Position = UDim2.new(0, 14, 0, 157)
loopBtn.BackgroundColor3 = Color3.fromRGB(65, 85, 105)
loopBtn.BackgroundTransparency = 0.1
loopBtn.Text = "Loop: ON"
loopBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
loopBtn.TextSize = 14
loopBtn.Font = Enum.Font.GothamBold
loopBtn.BorderSizePixel = 0
loopBtn.Parent = mainFrame
Instance.new("UICorner", loopBtn).CornerRadius = UDim.new(0, 7)

loopBtn.MouseButton1Click:Connect(function()
    isLooping = not isLooping
    if isLooping then
        loopBtn.Text = "Loop: ON"
        loopBtn.BackgroundColor3 = Color3.fromRGB(65, 85, 105)
        statusLabel.Text = "Looping Case " .. selectedCase .. "... | Anti-AFK Active"
        loopConnection = RunService.Heartbeat:Connect(function()
            local prompt = getPrompt(selectedCase)
            if prompt then
                prompt.HoldDuration = 0
                prompt.Enabled = true
                if fireproximityprompt then
                    fireproximityprompt(prompt)
                end
            end
        end)
    else
        loopBtn.Text = "Loop: OFF"
        loopBtn.BackgroundColor3 = Color3.fromRGB(52, 52, 60)
        statusLabel.Text = "Loop stopped | Anti-AFK Active"
        if loopConnection then
            loopConnection:Disconnect()
            loopConnection = nil
        end
    end
end)

-- Close functionality
closeBtn.MouseButton1Click:Connect(function()
    if loopConnection then loopConnection:Disconnect() end
    screenGui:Destroy()
end)

-- Dragging
local dragging = false
local dragStart = nil
local startPos = nil

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

titleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

-- ========================
-- ANTI-AFK (Always Active)
-- ========================
player.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

-- ========================
-- AUTO START: Case 10 loop
-- ========================
isLooping = true
statusLabel.Text = "Looping Case 10... | Anti-AFK Active"
loopConnection = RunService.Heartbeat:Connect(function()
    local prompt = getPrompt(selectedCase)
    if prompt then
        prompt.HoldDuration = 0
        prompt.Enabled = true
        if fireproximityprompt then
            fireproximityprompt(prompt)
        end
    end
end)
