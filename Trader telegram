-- MODULE: TradeState
-- Modifies table in-place so the Poller's reference stays valid.
-- ============================================================
local TradeState = {}
do
    TradeState._state = {}

    function TradeState.get() return TradeState._state end

    function TradeState.reset()
        local profile = Config.get()
        local s = TradeState._state
        -- Clear existing keys (preserves table reference for Poller)
        for k in pairs(s) do s[k] = nil end
        -- Re-initialise
        s.inventory     = {}
        s.selected      = {}
        s.tradeItems    = {}
        s.receiver      = profile.receiver or nil
        s.awaitingInput = nil
        s.chatId        = nil
        s.uiMessageId   = nil
        s.savedTrades   = Storage.load()
    end
end

-- ============================================================
-- MODULE: TradeExecutor
-- ============================================================
local TradeExecutor = {}
do
    function TradeExecutor.send(state)
        if not state.receiver or #state.receiver == 0 then
            return false, "❌ No receiver set."
        end

        if not next(state.tradeItems) then
            return false, "❌ No items selected."
        end

        local receiverPlayer = Players:FindFirstChild(state.receiver)
        if not receiverPlayer then
            return false, "❌ Player `" .. state.receiver .. "` is not in the server."
        end

        local itemsTable = {}
        for name, qty in pairs(state.tradeItems) do
            if qty > 0 then
                itemsTable[name] = math.min(qty, MAX_QTY_PER_ITEM)
            end
        end

        if not next(itemsTable) then
            return false, "❌ All item quantities are zero."
        end

        local args = {
            [1] = {
                ["SenderContents"] = {
                    ["Items"]    = itemsTable,
                    ["Currency"] = {},
                },
                ["Receiver"] = receiverPlayer,
                ["ReceiverContents"] = {
                    ["Items"]    = {},
                    ["Currency"] = {},
                },
            },
        }

        local ok, err = pcall(function()
            ReplicatedStorage
                .Remotes
                :FindFirstChild("Trade System")
                .SendTrade
                :InvokeServer(unpack(args))
        end)

        if not ok then
            return false, "❌ Remote error: `" .. tostring(err) .. "`"
        end

        return true, "✅ Trade sent to `" .. state.receiver .. "` successfully!"
    end
end

-- ============================================================
-- MODULE: UI
-- Single-message UI helper.
-- noFormat = true  → sends without parse_mode (raw text, safe for JSON)
-- noFormat = false/nil → uses Markdown
-- ============================================================
local UI = {}
do
    local cfg   = Config.get()
    local token = cfg.token

    function UI.render(state, text, keyboard, noFormat)
        if not state.chatId then return end

        local pm = (not noFormat) and "Markdown" or nil

        if state.uiMessageId then
            local result = TelegramAPI.editMessage(
                token, state.chatId, state.uiMessageId, text, keyboard, pm
            )
            if not result then
                local newMsg = TelegramAPI.sendMessage(token, state.chatId, text, keyboard, pm)
                if newMsg then state.uiMessageId = newMsg.message_id end
            end
        else
            local newMsg = TelegramAPI.sendMessage(token, state.chatId, text, keyboard, pm)
            if newMsg then state.uiMessageId = newMsg.message_id end
        end
    end

    function UI.toast(callbackId, text)
        TelegramAPI.answerCallback(token, callbackId, text)
    end
end

