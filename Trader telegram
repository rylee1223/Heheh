-- MODULE: Config
-- ============================================================
local Config = {}
do
    local cached, cachedIdx = nil, nil

    function Config.get()
        if cached then return cached, cachedIdx end

        local localId = Players.LocalPlayer.UserId

        for idx, profile in ipairs(PROFILES) do
            if profile.robloxId == localId then
                assert(type(profile.token) == "string" and #profile.token > 0,
                    "[Config] Profile #" .. idx .. " token is missing.")
                assert(type(profile.telegramId) == "number",
                    "[Config] Profile #" .. idx .. " telegramId must be a number.")

                cached, cachedIdx = profile, idx
                print(("[Config] Loaded profile #%d for Roblox ID %d (Telegram ID %d)")
                    :format(idx, profile.robloxId, profile.telegramId))
                return profile, idx
            end
        end

        error("[Config] No profile found for Roblox UserId " .. localId)
    end
end

-- ============================================================
-- MODULE: TelegramAPI
-- ============================================================
local TelegramAPI = {}
do
    local BASE = "https://api.telegram.org/bot"

    local httpRequest = (syn and syn.request)
        or (http and http.request)
        or http_request
        or (fluxus and fluxus.request)
        or request

    assert(httpRequest, "[TelegramAPI] No HTTP request function found. "
        .. "This script requires an executor with syn.request / http_request / request.")

    local function post(token, method, payload)
        local url  = BASE .. token .. "/" .. method
        local body = HttpService:JSONEncode(payload)

        local ok, response = pcall(httpRequest, {
            Url     = url,
            Method  = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body    = body,
        })

        if not ok or not response or not response.Body then
            warn("[TelegramAPI] Request failed on '" .. method .. "'")
            return nil
        end

        local decodeOk, decoded = pcall(HttpService.JSONDecode, HttpService, response.Body)
        if not decodeOk then
            warn("[TelegramAPI] JSON decode failed on '" .. method .. "'")
            return nil
        end

        if not decoded.ok then
            warn("[TelegramAPI] API error on '" .. method .. "': " .. tostring(decoded.description))
            return nil
        end

        return decoded.result
    end

    function TelegramAPI.getUpdates(token, offset)
        return post(token, "getUpdates", {
            offset          = offset,
            timeout         = 1,
            allowed_updates = {"message", "callback_query"},
        })
    end

    function TelegramAPI.sendMessage(token, chatId, text, replyMarkup, parseMode)
        local payload = {
            chat_id = chatId,
            text    = text,
        }
        if parseMode then
            payload.parse_mode = parseMode
        end
        if replyMarkup then
            payload.reply_markup = replyMarkup
        end
        return post(token, "sendMessage", payload)
    end

    function TelegramAPI.editMessage(token, chatId, messageId, text, replyMarkup, parseMode)
        local payload = {
            chat_id    = chatId,
            message_id = messageId,
            text       = text,
        }
        if parseMode then
            payload.parse_mode = parseMode
        end
        if replyMarkup then
            payload.reply_markup = replyMarkup
        end
        return post(token, "editMessageText", payload)
    end

    function TelegramAPI.deleteMessage(token, chatId, messageId)
        return post(token, "deleteMessage", {
            chat_id    = chatId,
            message_id = messageId,
        })
    end

    function TelegramAPI.answerCallback(token, callbackId, text)
        return post(token, "answerCallbackQuery", {
            callback_query_id = callbackId,
            text              = text or "",
        })
    end
end

-- ============================================================
-- MODULE: Storage
-- ============================================================
local Storage = {}
do
    local hasFileIO = (writefile and readfile and isfile) ~= nil

    function Storage.load()
        if not hasFileIO or not isfile(SAVE_FILE) then
            return {}
        end

        local ok, contents = pcall(readfile, SAVE_FILE)
        if not ok then return {} end

        local decodeOk, data = pcall(HttpService.JSONDecode, HttpService, contents)
        if not decodeOk or type(data) ~= "table" then
            return {}
        end

        return data
    end

    function Storage.save(savedTrades)
        if not hasFileIO then
            warn("[Storage] File I/O not available; trades won't persist between sessions.")
            return false
        end

        local ok, encoded = pcall(HttpService.JSONEncode, HttpService, savedTrades)
        if not ok then return false end

        local writeOk = pcall(writefile, SAVE_FILE, encoded)
        return writeOk
    end

    function Storage.available()
        return hasFileIO
    end
end

-- ============================================================
-- MODULE: Inventory
-- ============================================================
local Inventory = {}
do
    local LocalPlayer = Players.LocalPlayer

    function Inventory.snapshot()
        local inv = LocalPlayer.inventory
        if not inv then return {} end

        local snapshot = {}

        if typeof(inv) == "table" then
            for item, qty in pairs(inv) do
                if type(item) == "string" and type(qty) == "number" then
                    snapshot[item] = qty
                end
            end
        elseif typeof(inv) == "Instance" then
            for _, child in ipairs(inv:GetChildren()) do
                if child:IsA("NumberValue") or child:IsA("IntValue") then
                    snapshot[child.Name] = child.Value
                end
            end
        end

        return snapshot
    end

    function Inventory.format(snapshot)
        if not next(snapshot) then return "_Your inventory is empty._" end

        local lines  = {"*Your Inventory:*", ""}
        local sorted = {}
        for name, qty in pairs(snapshot) do
            table.insert(sorted, {name = name, qty = qty})
        end
        table.sort(sorted, function(a, b) return a.name < b.name end)

        for _, entry in ipairs(sorted) do
            table.insert(lines, string.format("• `%s` — x%d", entry.name, entry.qty))
        end

        return table.concat(lines, "\n")
    end
end

