-- MODULE: Keyboards
-- ============================================================
local Keyboards = {}
do
    local function markup(rows) return {inline_keyboard = rows} end

    function Keyboards.mainMenu()
        return markup({
            {
                {text = "📦 View Inventory", callback_data = "action:viewInventory"},
                {text = "🔄 Refresh",         callback_data = "action:refreshInventory"},
            },
            {
                {text = "🛒 Select Items",    callback_data = "action:selectItems"},
                {text = "🔢 Set Quantities",  callback_data = "action:setQuantities"},
            },
            {
                {text = "👤 Select Receiver", callback_data = "action:selectReceiver"},
                {text = "⚡ Quick Max (100)", callback_data = "action:quickMax"},
            },
            {
                {text = "📋 Load JSON",      callback_data = "action:loadJson"},
                {text = "💾 Export JSON",     callback_data = "action:exportJson"},
            },
            {
                {text = "📂 Saved Trades",    callback_data = "action:savedTrades"},
                {text = "📤 Send Trade",       callback_data = "action:sendTrade"},
            },
        })
    end

    function Keyboards.itemSelect(snapshot, selected)
        local rows, row, count = {}, {}, 0
        local sorted = {}
        for name in pairs(snapshot) do table.insert(sorted, name) end
        table.sort(sorted)

        for _, name in ipairs(sorted) do
            local icon = selected[name] and "✅" or "⬜"
            table.insert(row, {text = icon .. " " .. name, callback_data = "toggle:" .. name})
            count = count + 1
            if count % 2 == 0 then
                table.insert(rows, row); row = {}
            end
        end
        if #row > 0 then table.insert(rows, row) end

        table.insert(rows, {
            {text = "✅ Select All",  callback_data = "action:selectAll"},
            {text = "❌ Clear All",   callback_data = "action:clearAll"},
        })
        table.insert(rows, {
            {text = "✔️ Done",  callback_data = "action:mainMenu"},
        })

        return markup(rows)
    end

    function Keyboards.quantityEditor(tradeItems, inventory)
        local rows   = {}
        local sorted = {}
        for name in pairs(tradeItems) do table.insert(sorted, name) end
        table.sort(sorted)

        for _, name in ipairs(sorted) do
            local qty    = tradeItems[name]
            local maxQty = math.min(inventory[name] or MAX_QTY_PER_ITEM, MAX_QTY_PER_ITEM)
            table.insert(rows, {
                {text = string.format("%s: %d / %d", name, qty, maxQty), callback_data = "noop"},
            })
            table.insert(rows, {
                {text = "➖",     callback_data = "qty:dec:" .. name},
                {text = "✏️ Set", callback_data = "qty:set:" .. name},
                {text = "🔝 Max", callback_data = "qty:max:" .. name},
                {text = "➕",     callback_data = "qty:inc:" .. name},
            })
        end

        table.insert(rows, {
            {text = "⚡ All Max",  callback_data = "action:quickMax"},
            {text = "✔️ Done",    callback_data = "action:mainMenu"},
        })

        return markup(rows)
    end

    function Keyboards.receiverSelect(playerNames, currentReceiver)
        local rows = {}
        for _, name in ipairs(playerNames) do
            local icon = (name == currentReceiver) and "✅ " or ""
            table.insert(rows, {
                {text = icon .. name, callback_data = "receiver:" .. name},
            })
        end

        if #rows == 0 then
            table.insert(rows, {{text = "(no other players in server)", callback_data = "noop"}})
        end

        table.insert(rows, {
            {text = "🔄 Refresh",       callback_data = "action:selectReceiver"},
            {text = "✏️ Type Manually", callback_data = "action:receiverManual"},
        })
        table.insert(rows, {
            {text = "◀️ Back", callback_data = "action:mainMenu"},
        })

        return markup(rows)
    end

    function Keyboards.savedTrades(savedTrades)
        local rows = {}
        local sorted = {}
        for name in pairs(savedTrades) do table.insert(sorted, name) end
        table.sort(sorted)

        for _, name in ipairs(sorted) do
            table.insert(rows, {
                {text = "📂 " .. name,    callback_data = "load:" .. name},
                {text = "🗑️",             callback_data = "delete:" .. name},
            })
        end

        if #rows == 0 then
            table.insert(rows, {{text = "(no saved trades yet)", callback_data = "noop"}})
        end

        table.insert(rows, {
            {text = "💾 Save Current",   callback_data = "action:saveCurrent"},
            {text = "◀️ Back",          callback_data = "action:mainMenu"},
        })

        return markup(rows)
    end

    function Keyboards.jsonExport()
        return markup({
            {
                {text = "📋 Load JSON",  callback_data = "action:loadJson"},
                {text = "💾 Save to File", callback_data = "action:saveCurrent"},
            },
            {
                {text = "◀️ Main Menu",  callback_data = "action:mainMenu"},
            },
        })
    end

    function Keyboards.backOnly()
        return markup({{{text = "◀️ Main Menu", callback_data = "action:mainMenu"}}})
    end

    function Keyboards.confirmSend()
        return markup({
            {
                {text = "✅ Confirm",  callback_data = "action:confirmSend"},
                {text = "❌ Cancel",   callback_data = "action:mainMenu"},
            },
        })
    end
end

