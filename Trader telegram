-- MODULE: Screens
-- ============================================================
local Screens = {}
do
    local function countTable(t)
        local n = 0
        for _ in pairs(t) do n = n + 1 end
        return n
    end

    function Screens.mainMenu(state)
        local itemCount = countTable(state.tradeItems)
        local totalQty  = 0
        for _, q in pairs(state.tradeItems) do totalQty = totalQty + q end

        local text = table.concat({
            "*🤖 Trade Manager*",
            "",
            "👤 Account: `" .. Players.LocalPlayer.Name .. "`",
            "📥 Receiver: `" .. (state.receiver or "not set") .. "`",
            "📦 Items: `" .. itemCount .. "` (total qty: `" .. totalQty .. "`)",
            "💾 Saved trades: `" .. countTable(state.savedTrades) .. "`",
        }, "\n")

        UI.render(state, text, Keyboards.mainMenu())
    end

    function Screens.inventory(state)
        state.inventory = Inventory.snapshot()
        UI.render(state, Inventory.format(state.inventory), Keyboards.backOnly())
    end

    function Screens.selectItems(state)
        state.inventory = Inventory.snapshot()

        if not next(state.inventory) then
            UI.render(state, "⚠️ Your inventory is empty.", Keyboards.backOnly())
            return
        end

        UI.render(state,
            "*Select items to trade:*\nTap an item to toggle.",
            Keyboards.itemSelect(state.inventory, state.selected)
        )
    end

    function Screens.quantities(state)
        if not next(state.tradeItems) then
            UI.render(state,
                "⚠️ No items selected. Use *Select Items* first.",
                Keyboards.backOnly()
            )
            return
        end

        UI.render(state,
            "*Set quantities* (max " .. MAX_QTY_PER_ITEM .. " per item):",
            Keyboards.quantityEditor(state.tradeItems, state.inventory)
        )
    end

    function Screens.receivers(state)
        local list = ServerPlayers.list()
        local text = "*Select a receiver:*\n_(" .. #list .. " other player(s) in server)_"
        UI.render(state, text, Keyboards.receiverSelect(list, state.receiver))
    end

    function Screens.savedTrades(state)
        local count = countTable(state.savedTrades)
        local text  = "*💾 Saved Trades* (`" .. count .. "`)\n"

        if not Storage.available() then
            text = text .. "\n⚠️ _File I/O unavailable — saves won't persist between sessions._"
        end

        text = text .. "\n\nTap a name to load it, or 🗑️ to delete."

        UI.render(state, text, Keyboards.savedTrades(state.savedTrades))
    end

    function Screens.confirmSend(state)
        local lines = {"*📤 Confirm Trade*", ""}
        table.insert(lines, "Receiver: `" .. (state.receiver or "not set") .. "`")
        table.insert(lines, "Items:")

        local sorted = {}
        for name in pairs(state.tradeItems) do table.insert(sorted, name) end
        table.sort(sorted)

        for _, name in ipairs(sorted) do
            table.insert(lines, string.format("  • `%s` × %d", name, state.tradeItems[name]))
        end

        table.insert(lines, "")
        table.insert(lines, "_Confirm to send this trade._")

        UI.render(state, table.concat(lines, "\n"), Keyboards.confirmSend())
    end

    -- -------------------------------------------------------
    -- NEW: Export current trade as JSON text
    -- -------------------------------------------------------
    function Screens.exportJson(state)
        if not next(state.tradeItems) then
            UI.render(state, "⚠️ No items to export.\nSelect items first.", Keyboards.backOnly())
            return
        end

        local exportData = {
            items    = state.tradeItems,
            receiver = state.receiver or "",
        }

        local ok, jsonStr = pcall(HttpService.JSONEncode, HttpService, exportData)
        if not ok then
            UI.render(state, "❌ Failed to encode JSON.", Keyboards.backOnly())
            return
        end

        -- Send as plain text (no Markdown) so JSON is safe to copy
        local displayText = "💾 Trade JSON — copy the text below:\n\n" .. jsonStr
            .. "\n\n📋 Use 'Load JSON' and paste this text to restore the trade."

        UI.render(state, displayText, Keyboards.jsonExport(), true)  -- true = noFormat
    end

    -- -------------------------------------------------------
    -- NEW: Prompt user to paste JSON
    -- -------------------------------------------------------
    function Screens.loadJsonPrompt(state)
        state.awaitingInput = "loadJson"

        local exampleJson = HttpService:JSONEncode({items = {Sword = 5, Shield = 10}, receiver = "PlayerName"})

        local text = "📋 *Load Trade from JSON*\n\n"
            .. "Paste your trade JSON as a chat message.\n\n"
            .. "_Example format:_\n"
            .. exampleJson

        UI.render(state, text, Keyboards.backOnly())
    end
end

-- ============================================================
-- MODULE: MessageHandler
-- ============================================================
local MessageHandler = {}
do
    local cfg    = Config.get()
    local token  = cfg.token
    local authId = cfg.telegramId

    -- --------------------------------------------------------
    -- Action dispatcher
    -- --------------------------------------------------------
    local function handleAction(action, state, callbackId)

        if action == "mainMenu" then
            Screens.mainMenu(state)

        elseif action == "viewInventory" or action == "refreshInventory" then
            Screens.inventory(state)

        elseif action == "selectItems" then
            Screens.selectItems(state)

        elseif action == "selectAll" then
            state.inventory = Inventory.snapshot()
            for name in pairs(state.inventory) do
                state.selected[name] = true
                if not state.tradeItems[name] then
                    state.tradeItems[name] = 1
                end
            end
            Screens.selectItems(state)
            UI.toast(callbackId, "Selected all items")

        elseif action == "clearAll" then
            state.selected   = {}
            state.tradeItems = {}
            Screens.selectItems(state)
            UI.toast(callbackId, "Cleared all")

        elseif action == "setQuantities" then
            for name in pairs(state.selected) do
                if not state.tradeItems[name] then state.tradeItems[name] = 1 end
            end
            for name in pairs(state.tradeItems) do
                if not state.selected[name] then state.tradeItems[name] = nil end
            end
            Screens.quantities(state)

        elseif action == "quickMax" then
            state.inventory = Inventory.snapshot()

            if not next(state.selected) then
                for name in pairs(state.inventory) do
                    state.selected[name] = true
                end
            end

            for name in pairs(state.selected) do
                local invQty = state.inventory[name] or 0
                state.tradeItems[name] = math.min(invQty, MAX_QTY_PER_ITEM)
            end

            Screens.quantities(state)
            UI.toast(callbackId, "Set all to max (cap " .. MAX_QTY_PER_ITEM .. ")")

        elseif action == "selectReceiver" then
            Screens.receivers(state)

        elseif action == "receiverManual" then
            state.awaitingInput = "receiver"
            UI.render(state,
                "👤 *Type the exact Roblox username of the receiver:*\n_(Send as a chat message)_",
                Keyboards.backOnly()
            )

        elseif action == "savedTrades" then
            Screens.savedTrades(state)

        elseif action == "saveCurrent" then
            if not next(state.tradeItems) then
                UI.toast(callbackId, "❌ Nothing to save")
                return
            end
            state.awaitingInput = "saveName"
            UI.render(state,
                "💾 *Type a name for this saved trade:*\n_(Send as a chat message)_",
                Keyboards.backOnly()
            )

        -- =====================================================
        -- NEW: Export JSON
        -- =====================================================
        elseif action == "exportJson" then
            Screens.exportJson(state)

        -- =====================================================
        -- NEW: Load JSON prompt
        -- =====================================================
        elseif action == "loadJson" then
            Screens.loadJsonPrompt(state)

        elseif action == "sendTrade" then
            if not next(state.tradeItems) then
                UI.toast(callbackId, "❌ No items selected")
                return
            end
            if not state.receiver then
                UI.toast(callbackId, "❌ No receiver set")
                return
            end
            Screens.confirmSend(state)

        elseif action == "confirmSend" then
            UI.render(state, "⏳ Sending trade...", nil)
            local success, msg = TradeExecutor.send(state)

            -- Show result in same message, then return to menu
            UI.render(state, msg .. "\n\nReturning to main menu...", nil)
            wait(1.5)
            Screens.mainMenu(state)
        end
    end

    -- --------------------------------------------------------
    -- Toggle item selection
    -- --------------------------------------------------------
    local function handleToggle(itemName, state)
        if state.selected[itemName] then
            state.selected[itemName] = nil
            state.tradeItems[itemName] = nil
        else
            state.selected[itemName] = true
            state.tradeItems[itemName] = state.tradeItems[itemName] or 1
        end

        UI.render(state,
            "*Select items to trade:*\nTap an item to toggle.",
            Keyboards.itemSelect(state.inventory, state.selected)
        )
    end

    -- --------------------------------------------------------
    -- Quantity buttons
    -- --------------------------------------------------------
    local function handleQty(op, itemName, state, callbackId)
        if not state.tradeItems[itemName] then
            state.tradeItems[itemName] = 1
        end

        local invMax  = state.inventory[itemName] or MAX_QTY_PER_ITEM
        local hardMax = math.min(invMax, MAX_QTY_PER_ITEM)

        if op == "inc" then
            state.tradeItems[itemName] = math.min(state.tradeItems[itemName] + 1, hardMax)
            Screens.quantities(state)

        elseif op == "dec" then
            state.tradeItems[itemName] = math.max(state.tradeItems[itemName] - 1, 1)
            Screens.quantities(state)

        elseif op == "max" then
            state.tradeItems[itemName] = hardMax
            Screens.quantities(state)
            UI.toast(callbackId, "Set to " .. hardMax)

        elseif op == "set" then
            state.awaitingInput = "qty:" .. itemName
            UI.render(state,
                "✏️ *Type the quantity for `" .. itemName .. "`* (max " .. hardMax .. "):\n_(Send as a chat message)_",
                Keyboards.backOnly()
            )
        end
    end

    -- --------------------------------------------------------
    -- Receiver select from list
    -- --------------------------------------------------------
    local function handleReceiverPick(name, state, callbackId)
        state.receiver = name
        UI.toast(callbackId, "Receiver: " .. name)
        Screens.mainMenu(state)
    end

    -- --------------------------------------------------------
    -- Saved trade load / delete
    -- --------------------------------------------------------
    local function handleLoad(name, state, callbackId)
        local trade = state.savedTrades[name]
        if not trade then
            UI.toast(callbackId, "❌ Not found")
            return
        end

        state.tradeItems = {}
        state.selected   = {}
        for itemName, qty in pairs(trade.items or {}) do
            state.tradeItems[itemName] = qty
            state.selected[itemName]   = true
        end

        if trade.receiver and #trade.receiver > 0 then
            state.receiver = trade.receiver
        end

        UI.toast(callbackId, "Loaded: " .. name)
        Screens.mainMenu(state)
    end

    local function handleDelete(name, state, callbackId)
        if state.savedTrades[name] then
            state.savedTrades[name] = nil
            Storage.save(state.savedTrades)
            UI.toast(callbackId, "Deleted: " .. name)
        end
        Screens.savedTrades(state)
    end

    -- --------------------------------------------------------
    -- Text input handler (typed chat messages)
    -- --------------------------------------------------------
    local function handleTextInput(text, state)
        if not state.awaitingInput then return end

        local input = state.awaitingInput
        state.awaitingInput = nil

        if input == "receiver" then
            local name = text:match("^%s*(.-)%s*$")
            if name and #name > 0 then
                state.receiver = name
            end
            Screens.mainMenu(state)

        elseif input == "saveName" then
            local name = text:match("^%s*(.-)%s*$")
            if not name or #name == 0 then
                Screens.mainMenu(state)
                return
            end

            local snapshot = {items = {}, receiver = state.receiver}
            for k, v in pairs(state.tradeItems) do
                snapshot.items[k] = v
            end

            state.savedTrades[name] = snapshot
            Storage.save(state.savedTrades)
            Screens.savedTrades(state)

        -- =====================================================
        -- NEW: Load trade from pasted JSON text
        -- =====================================================
        elseif input == "loadJson" then
            local cleaned = text:match("^%s*(.-)%s*$") or text
            local decodeOk, data = pcall(HttpService.JSONDecode, HttpService, cleaned)

            if not decodeOk or type(data) ~= "table" then
                UI.render(state,
                    "❌ *Invalid JSON.* Please paste valid JSON.\n\nTry again or go back.",
                    Keyboards.backOnly()
                )
                -- Re-enable awaiting so they can retry
                state.awaitingInput = "loadJson"
                return
            end

            -- Clear current trade
            state.tradeItems = {}
            state.selected   = {}

            -- Load items
            if type(data.items) == "table" then
                for itemName, qty in pairs(data.items) do
                    if type(itemName) == "string" and type(qty) == "number" and qty > 0 then
                        state.tradeItems[itemName] = math.min(qty, MAX_QTY_PER_ITEM)
                        state.selected[itemName]   = true
                    end
                end
            end

            -- Load receiver
            if type(data.receiver) == "string" and #data.receiver > 0 then
                state.receiver = data.receiver
            end

            -- Update inventory snapshot for quantity editing
            state.inventory = Inventory.snapshot()

            local itemCount = 0
            for _ in pairs(state.tradeItems) do itemCount = itemCount + 1 end

            UI.render(state,
                "✅ *Trade loaded from JSON!*\n\n"
                .. "📦 " .. itemCount .. " item(s) loaded\n"
                .. "📥 Receiver: `" .. (state.receiver or "not set") .. "`",
                Keyboards.mainMenu()
            )

        elseif input:sub(1, 4) == "qty:" then
            local itemName = input:sub(5)
            local qty      = tonumber(text:match("^%s*(%d+)%s*$"))

            if qty and qty > 0 then
                local invMax  = state.inventory[itemName] or MAX_QTY_PER_ITEM
                local hardMax = math.min(invMax, MAX_QTY_PER_ITEM)
                state.tradeItems[itemName] = math.min(qty, hardMax)
            end
            Screens.quantities(state)
        end
    end

    -- --------------------------------------------------------
    -- Public: process one update
    -- --------------------------------------------------------
    function MessageHandler.processUpdate(update, state)

        if update.callback_query then
            local cq     = update.callback_query
            local fromId = cq.from and cq.from.id

            if fromId ~= authId then
                TelegramAPI.answerCallback(token, cq.id, "⛔ Unauthorized.")
                return
            end

            local chatId = cq.message and cq.message.chat and cq.message.chat.id
            local data   = cq.data or ""

            state.chatId      = chatId
            state.uiMessageId = cq.message.message_id

            -- Acknowledge quickly to remove loading spinner
            TelegramAPI.answerCallback(token, cq.id)

            if data:sub(1, 7) == "action:" then
                handleAction(data:sub(8), state, cq.id)

            elseif data:sub(1, 7) == "toggle:" then
                handleToggle(data:sub(8), state)

            elseif data:sub(1, 4) == "qty:" then
                local rest  = data:sub(5)
                local colon = rest:find(":")
                if colon then
                    local op       = rest:sub(1, colon - 1)
                    local itemName = rest:sub(colon + 1)
                    handleQty(op, itemName, state, cq.id)
                end

            elseif data:sub(1, 9) == "receiver:" then
                handleReceiverPick(data:sub(10), state, cq.id)

            elseif data:sub(1, 5) == "load:" then
                handleLoad(data:sub(6), state, cq.id)

            elseif data:sub(1, 7) == "delete:" then
                handleDelete(data:sub(8), state, cq.id)

            elseif data == "noop" then
                -- do nothing
            end

        elseif update.message then
            local msg    = update.message
            local fromId = msg.from and msg.from.id

            if fromId ~= authId then return end

            local chatId = msg.chat and msg.chat.id
            local text   = msg.text or ""
            state.chatId = chatId

            if text == "/start" then
                -- Preserve the existing UI message so we EDIT it, not create a new one
                local savedMsgId  = state.uiMessageId
                local savedChatId = state.chatId
                TradeState.reset()
                state.chatId      = savedChatId
                state.uiMessageId = savedMsgId
                Screens.mainMenu(state)
                return
            end

            if state.awaitingInput then
                handleTextInput(text, state)
                return
            end

            -- Unrecognised message → nudge via the same UI message (no spam)
            if state.uiMessageId then
                UI.render(state,
                    "⚠️ Send /start to open the Trade Manager.",
                    Keyboards.backOnly()
                )
            else
                -- No UI message yet; send one and track it
                UI.render(state,
                    "⚠️ Send /start to open the Trade Manager.",
                    Keyboards.backOnly()
                )
            end
        end
    end
end

-- ============================================================
-- MODULE: Poller
-- ============================================================
local Poller = {}
do
    local offset = 0

    function Poller.run()
        local cfg, idx = Config.get()
        local token    = cfg.token

        TradeState.reset()
        local state = TradeState.get()

        print(("[Poller] Trade Manager started. Profile #%d | Roblox ID %d | Telegram ID %d")
            :format(idx, cfg.robloxId, cfg.telegramId))
        print("[Poller] Send /start to your bot to begin.")

        local accumulator = 0
        RunService.Heartbeat:Connect(function(dt)
            accumulator = accumulator + dt
            if accumulator < POLL_INTERVAL then return end
            accumulator = 0

            local updates = TelegramAPI.getUpdates(token, offset)
            if not updates then return end

            for _, update in ipairs(updates) do
                offset = update.update_id + 1
                local ok, err = pcall(MessageHandler.processUpdate, update, state)
                if not ok then
                    warn("[Poller] Error processing update: " .. tostring(err))
                end
            end
        end)
    end
end

-- ============================================================
-- ENTRY POINT
-- ============================================================
Poller.run()
